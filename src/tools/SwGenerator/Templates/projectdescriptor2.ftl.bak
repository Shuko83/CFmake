<#-- Project Qt generation -->

<#assign project_name= doc.SwFactoryEntry.@Name>

<#if doc["/SwFactoryEntry/@IsOwnPluginInDistribution='yes'"]>
<#-- Assignation des repertoires en distribution interne-->
<#assign sw_dirs="../..">
<#assign sw_dirs_bin_win32="..\\..\\bin">
<#assign add_lib_dir="..\\..\\..\\lib">
<#assign import_lib_dir="lib">
<#assign src_dir="src">
<#assign rsc_dir="resources">


<#else>

<#-- Assignation des repertoires en distribution externe-->
<#assign sw_dirs="$"+"(SW_DIR)">
<#assign sw_dirs_bin_win32="$(SW_DIR)\\bin">
<#assign add_lib_dir="$$SW_DIR/lib">
<#assign import_lib_dir="lib">
<#assign src_dir="src">
<#assign rsc_dir="resources">
</#if>

<#assign sw_dirs_bin="${sw_dirs}/bin">
<#assign sw_dirs_src="${sw_dirs}/src">
<#assign sw_dirs_lib="${sw_dirs}/lib">
<#assign sw_dirs_include="${sw_dirs}/include">

<#-- Les donnees generees commencent ici-->

# -----------------------------------------------------------
# StreamWork Qt Plugin Project / Generated File
# -----------------------------------------------------------
TEMPLATE = lib
TARGET = ${project_name}
QT += core \
    xml
HEADERS += src/${doc.SwFactoryEntry.@Name}PluginFactory_Class.h
HEADERS += src/${project_name}Constantes.h
<#list doc.SwFactoryEntry?children as component>
<#if component?node_type = 'element'>
<#if component?node_name = "Components">
HEADERS += src/${component.@Name}.h 
</#if>
</#if>
</#list>


SOURCES += src/${doc.SwFactoryEntry.@Name}PluginFactory_Class.cpp
<#list doc.SwFactoryEntry?children as component>
<#if component?node_type = 'element'>
<#if component?node_name = "Components">
SOURCES += src/${component.@Name}.cpp
</#if>
</#if>
</#list>


OBJECTS_DIR += ./obj
RCC_DIR += ./intermediaire
UI_DIR += ./intermediaire
#Resource file(s)
RESOURCES += ./resources/"${project_name}Rsc.qrc"
DEFINES += "${project_name}_LIB"
INCLUDEPATH += src
<#if doc["/SwFactoryEntry/@IsOwnPluginInDistribution='yes'"]>
INCLUDEPATH += ../SwCore/include
INCLUDEPATH += ../SwExecution/include
INCLUDEPATH += ../SwGui/include
<#else>
INCLUDEPATH += ${sw_dirs_include}/SwCore
INCLUDEPATH += ${sw_dirs_include}/SwExecution
INCLUDEPATH += ${sw_dirs_include}/SwGui
</#if>

CONFIG(debug, debug|release) {
    TARGET = $$join(TARGET,,,d)
    OBJECTS_DIR = $$join(OBJECTS_DIR,,,d)
<#if doc["/SwFactoryEntry/@IsOwnPluginInDistribution='yes'"]>
    LIBS += -L"../SwCore/debug" \
    -L"../SwExecution/debug" \
<#else>
    LIBS += -L"${sw_dirs_lib}" \
</#if>
    -lSwCored \
    -lSwExecutiond \
    -lSwGuid
    TARGET_EXT = .swdld
} 
CONFIG(release, debug|release) {
<#if doc["/SwFactoryEntry/@IsOwnPluginInDistribution='yes'"]>
    LIBS += -L"../SwCore/release" \
    -L"../SwExecution/release" \
 <#else>
    LIBS += -L"${sw_dirs_lib}" \
</#if>
    -lSwCore \
    -lSwExecution \
    -lSwGui
    TARGET_EXT = .swdl
}

# -----------------------------------------------------------
# Surcharge de la regle install pour le deploiement des lib et headers
# -----------------------------------------------------------

win32{
    install_dynlib.commands=-$(INSTALL_FILE) "release\\*.swdl" "..\..\bin"
    install_sharedlib.commands=-$(INSTALL_FILE) "release\\*.lib" "..\..\lib"
    install_explib.commands=-$(INSTALL_FILE) "release\\*.exp" "..\..\lib"
    install_dynlibd.commands=-$(INSTALL_FILE) "debug\\*.swdld" "..\..\bin"
    install_sharedlibd.commands=-$(INSTALL_FILE) "debug\\*.lib" "..\..\lib"
    install_explibd.commands=-$(INSTALL_FILE) "debug\\*.exp" "..\..\lib"
    install_pdblibd.commands=-$(INSTALL_FILE) "debug\\*.pdb" "..\..\lib"
    install.depends=first install_dynlib install_sharedlib install_explib install_dynlibd install_sharedlibd install_explibd install_pdblibd FORCE
    QMAKE_EXTRA_TARGETS +=install_dynlib
    QMAKE_EXTRA_TARGETS +=install_sharedlib
    QMAKE_EXTRA_TARGETS +=install_explib
    QMAKE_EXTRA_TARGETS +=install_dynlibd
    QMAKE_EXTRA_TARGETS +=install_sharedlibd
    QMAKE_EXTRA_TARGETS +=install_explibd
    QMAKE_EXTRA_TARGETS +=install_pdblibd
    QMAKE_EXTRA_TARGETS +=install
}

