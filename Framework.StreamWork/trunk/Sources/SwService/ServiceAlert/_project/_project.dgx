        <Artifact name="QsException"/>
        <Artifact name="AlertManager"/>
        <Artifact name="SwCore"/>
        <Artifact name="SwExecution"/>
    </Dependencies>
    <QTDependencies>
        <Module name="core"/>
        <Module name="widgets"/>
    </QTDependencies>
</Project>
