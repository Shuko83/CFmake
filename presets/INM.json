{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 27,
        "patch": 0
    },

    "configurePresets": [
        {
            "name": "win_msvc15_x64",
            "description": "Configure project using Visual Studio 2015 (v140) in x64 for Windows",
            "binaryDir": "${sourceDir}/build/win-msvc2015-x64",
            "toolset": {
                "value": "v140",
                "strategy": "set"
            },
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "cacheVariables": {
            "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/win-msvc2015-x64/"
            }
        },

        {
            "name": "win_msvc15_x86",
            "description": "Configure project using Visual Studio 2015 (v140) in x86 for Windows",
            "binaryDir": "${sourceDir}/build/win-msvc2015-x86",
            "toolset": {
                "value": "v140",
                "strategy": "set"
            },
            "architecture": {
                "value": "win32",
                "strategy": "set"
            },
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/win-msvc2015-x86/"
            }
        },

        {
            "name": "unix",
            "displayName": "Unix",
            "description": "Configure project using ninja for unix",
            "generator": "Ninja Multi-Config",
            "binaryDir": "build/unix",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "debug;release",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/linux-gcc/"
            }
        },

        {
            "name": "win_bl2010_x86",
            "description": "Configure project using Borland 2010 in x86 for Windows",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/win-bl2010-x86",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "debug;release",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/win-bl2010-x86/",
                "CMAKE_C_COMPILER":"bcc32",
                "CMAKE_CXX_COMPILER":"bcc32"
            }
        }
    ],

    "buildPresets" : [
        {
            "name": "win_msvc2015_debug_x64",
            "configurePreset": "win_msvc15_x64",
            "configuration": "Debug",
            "targets": "install"
        },
        {
            "name": "win_msvc2015_release_x64",
            "configurePreset": "win_msvc15_x64",
            "configuration": "Release",
            "targets": "install"
        },
        {
            "name": "win_msvc2015_debug_x86",
            "configurePreset": "win_msvc15_x86",
            "configuration": "Debug",
            "targets": "install"
        },
        {
            "name": "win_msvc2015_release_x86",
            "configurePreset": "win_msvc15_x86",
            "configuration": "Release",
            "targets": "install"
        },
        {
            "name": "unix_debug",
            "configurePreset": "unix",
            "configuration": "Debug",
            "targets": ["all","install"],
            "jobs": 4
        },
        {
            "name": "unix_release",
            "configurePreset": "unix",
            "configuration": "Release",
            "targets": ["all","install"],
            "jobs": 4
        },
        {
            "name": "win_bl2010_debug_x86",
            "configurePreset": "win_bl2010_x86",
            "configuration": "Debug",
            "targets": ["all","install"]
        },
        {
            "name": "win_bl2010_release_x86",
            "configurePreset": "win_bl2010_x86",
            "configuration": "Release",
            "targets": ["all","install"]
        }
    ],

    "workflowPresets":[
        {
            "name": "build_win_msvc2015_x64",
            "steps":[
                { "type":"configure", "name":"win_msvc15_x64" },
                { "type":"build", "name":"win_msvc2015_debug_x64" },
                { "type":"build", "name":"win_msvc2015_release_x64" }
            ]
        },
        {
            "name": "build_win_msvc2015_x86",
            "steps":[
                { "type":"configure", "name":"win_msvc15_x86" },
                { "type":"build", "name":"win_msvc2015_debug_x86" },
                { "type":"build", "name":"win_msvc2015_release_x86" }
            ]
        },
        {
            "name": "build_unix",
            "steps":[
                { "type":"configure", "name":"unix" },
                { "type":"build", "name":"unix_debug" },
                { "type":"build", "name":"unix_release" }
            ]
        },
        {
            "name": "build_win_bl2010_x86",
            "steps":[
                { "type":"configure", "name":"win_bl2010_x86" },
                { "type":"build", "name":"win_bl2010_debug_x86" },
                { "type":"build", "name":"win_bl2010_release_x86" }
            ]
        },

        {
            "name": "dev_win_msvc2015_x64",
            "steps":[
                { "type":"configure", "name":"win_msvc15_x64" }
            ]
        },
        {
            "name": "dev_win_msvc2015_x86",
            "steps":[
                { "type":"configure", "name":"win_msvc15_x86" }
            ]
        },
        {
            "name": "dev_unix",
            "steps":[
                { "type":"configure", "name":"unix" }
            ]
        }
    ]
}
