# This is a basic Config file for find_package() generated by CSToolkit.
# 
# This file was generated by the use of LEGACY option with cstoolkit_fetch_package.
# 
# If the package does not implement the standard expected by this file 
# you can write your own Find@fetch_package_name@.cmake file and add its folder to CMAKE_MODULE_PATH
#   list(APPEND CMAKE_MODULE_PATH "${CMAKE_SOURCE_DIR}/cmake")

set(@fetch_package_name@_ROOT_DIR "${CMAKE_CURRENT_LIST_DIR}")

file(GLOB_RECURSE _STATIC_LIB_LIST "${@fetch_package_name@_ROOT_DIR}/*.a")
set(_RELEASE_STATIC_LIB_LIST ${_STATIC_LIB_LIST})
list(FILTER _RELEASE_STATIC_LIB_LIST INCLUDE REGEX "/[Rr]elease/")
list(FILTER _STATIC_LIB_LIST EXCLUDE REGEX "/[Rr]elease/")
list(FILTER _STATIC_LIB_LIST EXCLUDE REGEX "/[Dd]ebug/")

file(GLOB_RECURSE _SHARED_LIB_LIST "${@fetch_package_name@_ROOT_DIR}/*.so")
set(_RELEASE_SHARED_LIB_LIST ${_SHARED_LIB_LIST})
list(FILTER _RELEASE_SHARED_LIB_LIST INCLUDE REGEX "/[Rr]elease/")
list(FILTER _SHARED_LIB_LIST EXCLUDE REGEX "/[Rr]elease/")
list(FILTER _SHARED_LIB_LIST EXCLUDE REGEX "/[Dd]ebug/")

foreach(_releaselib ${_RELEASE_STATIC_LIB_LIST})
    get_filename_component(_filename ${_releaselib} NAME_WE)
    string(REGEX REPLACE "^lib" "" _libname "${_filename}")
    
    if(TARGET @fetch_package_name@::${_libname})
        return()
    endif()

    set(_includedir "${_releaselib}/../../../include")
    cmake_path(NORMAL_PATH _includedir)
    if(NOT EXISTS ${_includedir})
        unset(_includedir)
    endif()

    file(GLOB_RECURSE _debuglib_list "${@fetch_package_name@_ROOT_DIR}*/${_filename}d.a" "${@fetch_package_name@_ROOT_DIR}*/${_filename}.a")
    list(FILTER _debuglib_list INCLUDE REGEX "/[Dd]ebug/")
    list(POP_FRONT _debuglib_list _debuglib)

    if(NOT EXISTS "${_debuglib}")
        set(_debuglib "${_releaselib}")
    endif()

    add_library(@fetch_package_name@::${_libname} STATIC IMPORTED)
    if(DEFINED _includedir)
        set_target_properties(@fetch_package_name@::${_libname} PROPERTIES INTERFACE_INCLUDE_DIRECTORIES "${_includedir}")
    endif()
    set_target_properties(@fetch_package_name@::${_libname} PROPERTIES
        IMPORTED_CONFIGURATIONS "RELEASE;DEBUG"
        IMPORTED_LINK_INTERFACE_LANGUAGES_RELEASE "CXX"
        IMPORTED_LOCATION_RELEASE "${_releaselib}"
        IMPORTED_LINK_INTERFACE_LANGUAGES_DEBUG "CXX"
        IMPORTED_LOCATION_DEBUG "${_debuglib}"
    )

    list(APPEND @fetch_package_name@_LIBRARIES "@fetch_package_name@::${_libname}")
endforeach()

foreach(_lib ${_STATIC_LIB_LIST})
    get_filename_component(_filename ${_lib} NAME_WE)

    string(REGEX REPLACE "d$" "" _release_filename "${_filename}")
    set(_debug_filename "${_filename}d")

    if(NOT _filename STREQUAL _release_filename)
        file(GLOB_RECURSE _releaselib_list "${@fetch_package_name@_ROOT_DIR}*/${_release_filename}.a")
        list(POP_FRONT _releaselib_list _releaselib)
    endif()
    if(NOT _filename STREQUAL _debug_filename)
        file(GLOB_RECURSE _debuglib_list "${@fetch_package_name@_ROOT_DIR}*/${_debug_filename}.a")
        list(POP_FRONT _debuglib_list _debuglib)
    endif()

    if(EXISTS "${_debuglib}")
        set(_releaselib "${_lib}")
    elseif(EXISTS "${_releaselib}")
        set(_debuglib "${_lib}")
    else()
        set(_releaselib "${_lib}")
        set(_debuglib "${_lib}")
    endif()

    get_filename_component(_release_filename ${_releaselib} NAME_WE)
    string(REGEX REPLACE "^lib" "" _libname "${_release_filename}")
    
    if(TARGET @fetch_package_name@::${_libname})
        return()
    endif()

    set(_includedir "${_releaselib}/../../include")
    cmake_path(NORMAL_PATH _includedir)
    if(NOT EXISTS ${_includedir})
        unset(_includedir)
    endif()

    add_library(@fetch_package_name@::${_libname} STATIC IMPORTED)
    if(DEFINED _includedir)
        set_target_properties(@fetch_package_name@::${_libname} PROPERTIES INTERFACE_INCLUDE_DIRECTORIES "${_includedir}")
    endif()
    set_target_properties(@fetch_package_name@::${_libname} PROPERTIES
        IMPORTED_CONFIGURATIONS "RELEASE;DEBUG"
        IMPORTED_LINK_INTERFACE_LANGUAGES_RELEASE "CXX"
        IMPORTED_LOCATION_RELEASE "${_releaselib}"
        IMPORTED_LINK_INTERFACE_LANGUAGES_DEBUG "CXX"
        IMPORTED_LOCATION_DEBUG "${_debuglib}"
    )

    list(APPEND @fetch_package_name@_LIBRARIES "@fetch_package_name@::${_libname}")
endforeach()

foreach(_releaselib ${_RELEASE_SHARED_LIB_LIST})
    get_filename_component(_filename ${_releaselib} NAME_WE)
    string(REGEX REPLACE "^lib" "" _libname "${_filename}")
    
    if(TARGET @fetch_package_name@::${_libname})
        return()
    endif()

    set(_includedir "${_releaselib}/../../../include")
    cmake_path(NORMAL_PATH _includedir)
    if(NOT EXISTS ${_includedir})
        unset(_includedir)
    endif()

    file(GLOB_RECURSE _debuglib_list "${@fetch_package_name@_ROOT_DIR}*/${_filename}d.so" "${@fetch_package_name@_ROOT_DIR}*/${_filename}.so")
    list(FILTER _debuglib_list INCLUDE REGEX "/[Dd]ebug/")
    list(POP_FRONT _debuglib_list _debuglib)

    if(NOT EXISTS "${_debuglib}")
        set(_debuglib "${_releaselib}")
    endif()

    add_library(@fetch_package_name@::${_libname} SHARED IMPORTED)
    if(DEFINED _includedir)
        set_target_properties(@fetch_package_name@::${_libname} PROPERTIES INTERFACE_INCLUDE_DIRECTORIES "${_includedir}")
    endif()
    set_target_properties(@fetch_package_name@::${_libname} PROPERTIES
        IMPORTED_CONFIGURATIONS "RELEASE;DEBUG"
        IMPORTED_LOCATION_RELEASE "${_releaselib}"
        IMPORTED_LOCATION_DEBUG "${_debuglib}"
        IMPORTED_NO_SONAME 1
    )

    list(APPEND @fetch_package_name@_LIBRARIES "@fetch_package_name@::${_libname}")
endforeach()

foreach(_lib ${_SHARED_LIB_LIST})
    get_filename_component(_filename ${_lib} NAME_WE)

    string(REGEX REPLACE "d$" "" _release_filename "${_filename}")
    set(_debug_filename "${_filename}d")

    if(NOT _filename STREQUAL _release_filename)
        file(GLOB_RECURSE _releaselib_list "${@fetch_package_name@_ROOT_DIR}*/${_release_filename}.so")
        list(POP_FRONT _releaselib_list _releaselib)
    endif()
    if(NOT _filename STREQUAL _debug_filename)
        file(GLOB_RECURSE _debuglib_list "${@fetch_package_name@_ROOT_DIR}*/${_debug_filename}.so")
        list(POP_FRONT _debuglib_list _debuglib)
    endif()

    if(EXISTS "${_debuglib}")
        set(_releaselib "${_lib}")
    elseif(EXISTS "${_releaselib}")
        set(_debuglib "${_lib}")
    else()
        set(_releaselib "${_lib}")
        set(_debuglib "${_lib}")
    endif()

    get_filename_component(_release_filename ${_releaselib} NAME_WE)
    string(REGEX REPLACE "^lib" "" _libname "${_release_filename}")
    
    if(TARGET @fetch_package_name@::${_libname})
        return()
    endif()

    set(_includedir "${_releaselib}/../../include")
    cmake_path(NORMAL_PATH _includedir)
    if(NOT EXISTS ${_includedir})
        unset(_includedir)
    endif()

    add_library(@fetch_package_name@::${_libname} SHARED IMPORTED)
    if(DEFINED _includedir)
        set_target_properties(@fetch_package_name@::${_libname} PROPERTIES INTERFACE_INCLUDE_DIRECTORIES "${_includedir}")
    endif()
    set_target_properties(@fetch_package_name@::${_libname} PROPERTIES
        IMPORTED_CONFIGURATIONS "RELEASE;DEBUG"
        IMPORTED_LOCATION_RELEASE "${_releaselib}"
        IMPORTED_LOCATION_DEBUG "${_debuglib}"
        IMPORTED_NO_SONAME 1
    )

    list(APPEND @fetch_package_name@_LIBRARIES "@fetch_package_name@::${_libname}")
endforeach()

if(NOT @fetch_package_name@_LIBRARIES)
    file(GLOB_RECURSE _INCLUDE_DIR_LIST LIST_DIRECTORIES true "${@fetch_package_name@_ROOT_DIR}/*include")
    list(FILTER _INCLUDE_DIR_LIST INCLUDE REGEX "/include$")
    foreach(_includedir ${_INCLUDE_DIR_LIST})
        if(IS_DIRECTORY  ${_includedir})
            set(_targetdir "${_includedir}/..")
            cmake_path(NORMAL_PATH _targetdir)
            get_filename_component(_libname ${_targetdir} NAME)

            if(TARGET @fetch_package_name@::${_libname})
                return()
            endif()

            add_library(@fetch_package_name@::${_libname} INTERFACE IMPORTED)
            set_target_properties(@fetch_package_name@::${_libname} PROPERTIES INTERFACE_INCLUDE_DIRECTORIES "${_includedir}")
        endif()
    endforeach()
endif()

# handle the QUIETLY and REQUIRED arguments and set xxx_FOUND to TRUE if
# all listed variables are TRUE
include(FindPackageHandleStandardArgs)
find_package_handle_standard_args(@fetch_package_name@ DEFAULT_MSG
    @fetch_package_name@_ROOT_DIR @fetch_package_name@_LIBRARIES)
