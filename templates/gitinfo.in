# .gitinfo - Git metadata

# Current tree state
current_tree: @CFMAKE_GIT_COMMIT@

# Last known Git commit (hash)
last_commit: @CFMAKE_GIT_SHA@

# Last commit date (RFC 2822)
last_commit_date: @CFMAKE_GIT_DATE@

# Current branch name
branch: @CFMAKE_GIT_BRANCH@

# Remote tracking URL
remote_origin: @CFMAKE_GIT_URL@

# Tag (if any) this commit corresponds to
tag: @CFMAKE_GIT_TAG@

# Relative path to the top level of the source tree
source_dir: @CFMAKE_GIT_RELATIVE_TOP_LEVEL@

# Timestamp this file was generated
timestamp: @CFMAKE_CONFIGURATION_DATE@

# Generated by CFMake
