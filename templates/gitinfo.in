# .gitinfo - Git metadata

# Current tree state
current_tree: @CSTOOLKIT_GIT_COMMIT@

# Last known Git commit (hash)
last_commit: @CSTOOLKIT_GIT_SHA@

# Last commit date (RFC 2822)
last_commit_date: @CSTOOLKIT_GIT_DATE@

# Current branch name
branch: @CSTOOLKIT_GIT_BRANCH@

# Remote tracking URL
remote_origin: @CSTOOLKIT_GIT_URL@

# Tag (if any) this commit corresponds to
tag: @CSTOOLKIT_GIT_TAG@

# Relative path to the top level of the source tree
source_dir: @CSTOOLKIT_GIT_RELATIVE_TOP_LEVEL@

# Timestamp this file was generated
timestamp: @CSTOOLKIT_CONFIGURATION_DATE@

# Generated by CSToolkit
