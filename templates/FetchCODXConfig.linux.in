# This is a basic Config file for find_package() generated by CSToolkit.
# 
# This file was generated by the use of CODX option with cstoolkit_fetch_package.

if(TARGET @fetch_package_name@::Elements)
    return()
endif()

set(@fetch_package_name@_ROOT_DIR "${CMAKE_CURRENT_LIST_DIR}")

file(GLOB_RECURSE _LIB_LIST "${@fetch_package_name@_ROOT_DIR}/*.so")
list(FILTER _LIB_LIST INCLUDE REGEX "/release/")

foreach(_releaselib ${_LIB_LIST})
    get_filename_component(_filename ${_releaselib} NAME_WE)

    if(_filename MATCHES "Messages")
        set(_libname "Messages")
    elseif(_filename MATCHES "Elements")
        set(_libname "Elements")
    else()
        set(@fetch_package_name@_FOUND FALSE)
        set(@fetch_package_name@_NOT_FOUND_MESSAGE "Unexpected File '${_filename}'")
        if(NOT @fetch_package_name@_REQUIRED AND NOT @fetch_package_name@_QUIETLY)
            message(WARNING "Unexpected File '${_filename}'")
        endif()
        return()
    endif()

    set(_includedir "${@fetch_package_name@_ROOT_DIR}/include")

    string(REPLACE "/release/" "/debug/" _debuglib ${_releaselib})
    string(REPLACE ".so" "d.so" _debuglib ${_debuglib})

    add_library(@fetch_package_name@::${_libname} SHARED IMPORTED)
    set_target_properties(@fetch_package_name@::${_libname} PROPERTIES INTERFACE_INCLUDE_DIRECTORIES "${_includedir}")
    set_target_properties(@fetch_package_name@::${_libname} PROPERTIES
        IMPORTED_CONFIGURATIONS "RELEASE;DEBUG"
        IMPORTED_LOCATION_RELEASE "${_releaselib}"
        IMPORTED_LOCATION_DEBUG "${_debuglib}"
        IMPORTED_NO_SONAME 1
    )

    if(_libname STREQUAL "Messages")
        set_target_properties(@fetch_package_name@::${_libname} PROPERTIES INTERFACE_LINK_LIBRARIES "@fetch_package_name@::Elements")
    endif()

    list(APPEND @fetch_package_name@_LIBRARIES "@fetch_package_name@::${_libname}")
endforeach()

# handle the QUIETLY and REQUIRED arguments and set xxx_FOUND to TRUE if
# all listed variables are TRUE
include(FindPackageHandleStandardArgs)
find_package_handle_standard_args(@fetch_package_name@ DEFAULT_MSG
    @fetch_package_name@_ROOT_DIR @fetch_package_name@_LIBRARIES)
