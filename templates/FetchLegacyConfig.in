# This is a basic Config file for find_package() generated by CSToolkit.
# 
# This file was generated by the use of LEGACY option with cstoolkit_fetch_artifactory.
# 
# If the package does not implement the standard expected by this file 
# you can write your own Find@PACKAGE_NAME@.cmake file and add its folder to CMAKE_MODULE_PATH
#   list(APPEND CMAKE_MODULE_PATH "${CMAKE_SOURCE_DIR}/cmake")

set(@PACKAGE_NAME@_ROOT_DIR "${CSTOOLKIT_EXTERNALS}/@PACKAGE_NAME@")

file(GLOB_RECURSE _LIB_LIST "${@PACKAGE_NAME@_ROOT_DIR}/*.lib")
list(FILTER _LIB_LIST INCLUDE REGEX "[Rr]elease/[^/]+\.lib")

# if list empty error

foreach(_releaselib ${_LIB_LIST})
    get_filename_component(_libname ${_releaselib} NAME_WE)
    
    if (TARGET @PACKAGE_NAME@::${_libname})
        continue()
    endif()

    set(_includedir "${_releaselib}/../../../include")
    cmake_path(NORMAL_PATH _includedir)

    # if _includedir not exists error

    set(_binfolder "${_releaselib}/../..")
    cmake_path(NORMAL_PATH _binfolder)

    file(GLOB _debuglib "${_binfolder}[Dd]ebug/${_libname}d.lib")

    # if _debuglib size != 1 error

    STRING(REPLACE ".lib" ".dll" _releasedll ${_releaselib})
    STRING(REPLACE ".lib" ".dll" _debugdll ${_debuglib})

    if(EXISTS "${_releasedll}")
        # if _debugdll not exists error

        # Recuperation des dlls suplementaires
        set(_binfolderrelease "${_releaselib}/..")
        cmake_path(NORMAL_PATH _binfolderrelease)
        file(GLOB _runtimedllsrelease "${_binfolderrelease}*.dll")

        set(_binfolderdebug "${_debuglib}/..")
        cmake_path(NORMAL_PATH _binfolderdebug)
        file(GLOB _runtimedllsdebug "${_binfolderdebug}*.dll")

        add_library(@PACKAGE_NAME@::${_libname} SHARED IMPORTED)
        set_target_properties(@PACKAGE_NAME@::${_libname} PROPERTIES
            INTERFACE_INCLUDE_DIRECTORIES "${_includedir}"
            IMPORTED_CONFIGURATIONS "RELEASE;DEBUG"
            IMPORTED_IMPLIB_RELEASE "${_releaselib}"
            IMPORTED_LOCATION_RELEASE "${_releasedll}"
            IMPORTED_IMPLIB_DEBUG "${_debuglib}"
            IMPORTED_LOCATION_DEBUG "${_debugdll}"
        )
    else()
        # if _debugdll exists error

        add_library(@PACKAGE_NAME@::${_libname} STATIC IMPORTED)
        set_target_properties(@PACKAGE_NAME@::${_libname} PROPERTIES
            INTERFACE_INCLUDE_DIRECTORIES "${_includedir}"
            IMPORTED_CONFIGURATIONS "RELEASE;DEBUG"
            IMPORTED_LINK_INTERFACE_LANGUAGES_RELEASE "CXX"
            IMPORTED_LOCATION_RELEASE "${_releaselib}"
            IMPORTED_LINK_INTERFACE_LANGUAGES_DEBUG "CXX"
            IMPORTED_LOCATION_DEBUG "${_debuglib}"
            RUNTIME_DLLS_DEBUG "${_runtimedllsdebug}"
            RUNTIME_DLLS_RELEASE "${_runtimedllsrelease}"
        )
    endif()

    list(APPEND @PACKAGE_NAME@_LIBRARIES "@PACKAGE_NAME@::${_libname}")
endforeach()

unset(_libname)
unset(_includedir)
unset(_releaselib)
unset(_releasedll)
unset(_debuglib)
unset(_debugdll)
unset(_LIB_LIST)

# handle the QUIETLY and REQUIRED arguments and set xxx_FOUND to TRUE if
# all listed variables are TRUE
include(FindPackageHandleStandardArgs)
find_package_handle_standard_args(@PACKAGE_NAME@ DEFAULT_MSG
    @PACKAGE_NAME@_ROOT_DIR @PACKAGE_NAME@_LIBRARIES)
