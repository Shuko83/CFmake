if(NOT @PROJECT_NAME@_FIND_COMPONENTS)
    set(@PROJECT_NAME@_FIND_COMPONENTS @CFMAKE_INSTALLED_TARGETS@)
@FIND_REQUIRED_COMPONENTS@
endif()

string(SHA256 @PROJECT_NAME@_fp_call_hash "@PROJECT_NAME@;${@PROJECT_NAME@_FIND_COMPONENTS};${@PROJECT_NAME@_FIND_REQUIRED};${@PROJECT_NAME@_FIND_QUIETLY}")

foreach(component ${@PROJECT_NAME@_FIND_COMPONENTS})
    list(APPEND @PROJECT_NAME@_HASH_STACK ${@PROJECT_NAME@_fp_call_hash})
    find_package(@PROJECT_NAME@_${component}
        QUIET
        PATHS ${CMAKE_CURRENT_LIST_DIR}/${component}/cmake CONFIG NO_DEFAULT_PATH
    )
    list(POP_BACK @PROJECT_NAME@_HASH_STACK @PROJECT_NAME@_fp_call_hash)
    if(NOT @PROJECT_NAME@_${component}_FOUND)
        if(@PROJECT_NAME@_FIND_REQUIRED_${component})
            if(@PROJECT_NAME@_${component}_NOT_FOUND_MESSAGE)
                set(_${@PROJECT_NAME@_fp_call_hash}_NOTFOUND_MESSAGE "${_${@PROJECT_NAME@_fp_call_hash}_NOTFOUND_MESSAGE}Error processing @PROJECT_NAME@ component \"${component}\" config file at \"${CMAKE_CURRENT_LIST_DIR}/${component}/cmake/@PROJECT_NAME@_${component}Config.cmake\": ${@PROJECT_NAME@_${component}_NOT_FOUND_MESSAGE}\n")
            else()
                set(_${@PROJECT_NAME@_fp_call_hash}_NOTFOUND_MESSAGE "${_${@PROJECT_NAME@_fp_call_hash}_NOTFOUND_MESSAGE}Failed to find @PROJECT_NAME@ component \"${component}\" config file at \"${CMAKE_CURRENT_LIST_DIR}/${component}/cmake/@PROJECT_NAME@_${component}Config.cmake\"\n")
            endif()
        elseif(NOT @PROJECT_NAME@_FIND_QUIETLY)
            if(@PROJECT_NAME@_${component}_NOT_FOUND_MESSAGE)
                message(WARNING "Error processing @PROJECT_NAME@ component \"${component}\" config file at \"${CMAKE_CURRENT_LIST_DIR}/${component}/cmake/@PROJECT_NAME@_${component}Config.cmake\": ${@PROJECT_NAME@_${component}_NOT_FOUND_MESSAGE}")
            else()
                message(WARNING "Failed to find @PROJECT_NAME@ component \"${component}\" config file at \"${CMAKE_CURRENT_LIST_DIR}/${component}/cmake/@PROJECT_NAME@_${component}Config.cmake\"")
            endif()
        endif()
    endif()
endforeach()

if(_${@PROJECT_NAME@_fp_call_hash}_NOTFOUND_MESSAGE)
    set(@PROJECT_NAME@_NOT_FOUND_MESSAGE "${_${@PROJECT_NAME@_fp_call_hash}_NOTFOUND_MESSAGE}")
    set(@PROJECT_NAME@_FOUND False)
else()
    unset(@PROJECT_NAME@_NOT_FOUND_MESSAGE)
    set(@PROJECT_NAME@_FOUND True)
endif()
