if(NOT @PROJECT_NAME@_FIND_COMPONENTS)
    set(@PROJECT_NAME@_FIND_COMPONENTS @CSTOOLKIT_INSTALL_TARGETS_ALL@)
endif()

set(_@PROJECT_NAME@_FIND_PARTS_REQUIRED)
if(@PROJECT_NAME@_FIND_REQUIRED)
    set(_@PROJECT_NAME@_FIND_PARTS_REQUIRED REQUIRED)
endif()
set(_@PROJECT_NAME@_FIND_PARTS_QUIET)
if(@PROJECT_NAME@_FIND_QUIETLY)
    set(_@PROJECT_NAME@_FIND_PARTS_QUIET QUIET)
endif()

foreach(component ${@PROJECT_NAME@_FIND_COMPONENTS})
  find_package(@PROJECT_NAME@_${component}
    ${_@PROJECT_NAME@_FIND_PARTS_QUIET}
    ${_@PROJECT_NAME@_FIND_PARTS_REQUIRED}
    PATHS ${CMAKE_CURRENT_LIST_DIR}/${component}/cmake CONFIG NO_DEFAULT_PATH
  )
  if(NOT @PROJECT_NAME@_${component}_FOUND)
    if(@PROJECT_NAME@_FIND_REQUIRED_${component})
      if(@PROJECT_NAME@_${component}_NOT_FOUND_MESSAGE)
        set(_@PROJECT_NAME@_NOTFOUND_MESSAGE "${_@PROJECT_NAME@_NOTFOUND_MESSAGE}Error processing @PROJECT_NAME@ component \"${component}\" config file at \"${CMAKE_CURRENT_LIST_DIR}/${component}/cmake/@PROJECT_NAME@_${component}Config.cmake\": ${@PROJECT_NAME@_${component}_NOT_FOUND_MESSAGE}\n")
      else()
        set(_@PROJECT_NAME@_NOTFOUND_MESSAGE "${_@PROJECT_NAME@_NOTFOUND_MESSAGE}Failed to find @PROJECT_NAME@ component \"${component}\" config file at \"${CMAKE_CURRENT_LIST_DIR}/${component}/cmake/@PROJECT_NAME@_${component}Config.cmake\"\n")
      endif()
    elseif(NOT @PROJECT_NAME@_FIND_QUIETLY)
      message(WARNING "Failed to find @PROJECT_NAME@ component \"${component}\" config file at \"${CMAKE_CURRENT_LIST_DIR}/${component}/cmake/@PROJECT_NAME@_${component}Config.cmake\"")
    endif()
  endif()
endforeach()

if(_@PROJECT_NAME@_NOTFOUND_MESSAGE)
  set(@PROJECT_NAME@_NOT_FOUND_MESSAGE "${_@PROJECT_NAME@_NOTFOUND_MESSAGE}")
  set(@PROJECT_NAME@_FOUND False)
endif()
