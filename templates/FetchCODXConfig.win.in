# This is a basic Config file for find_package() generated by CSToolkit.
# 
# This file was generated by the use of CODX option with cstoolkit_fetch_package.

if(TARGET @fetch_package_name@::Elements)
    return()
endif()

set(@fetch_package_name@_ROOT_DIR "${CMAKE_CURRENT_LIST_DIR}")

file(GLOB_RECURSE _DLL_LIST "${@fetch_package_name@_ROOT_DIR}/*.dll")
list(FILTER _DLL_LIST INCLUDE REGEX "${@fetch_package_name@_ROOT_DIR}/.*/release/")

set(@fetch_package_name@_MULTI_ELEMENTS 0)
foreach(_releasedll ${_DLL_LIST})
    get_filename_component(_dllname ${_releasedll} NAME_WE)
    if(_releasedll MATCHES "Elements1")
        set(@fetch_package_name@_MULTI_ELEMENTS 1)
        break()
    endif()
endforeach()

if(@fetch_package_name@_MULTI_ELEMENTS)
    add_library(@fetch_package_name@::Elements INTERFACE IMPORTED)
endif()

foreach(_releasedll ${_DLL_LIST})
    get_filename_component(_filename ${_releasedll} NAME_WE)

    if(_filename MATCHES "Messages")
        set(_dllname "Messages")
    elseif(_filename MATCHES "(Elements[0-9]+)")
        set(_dllname "${CMAKE_MATCH_1}")
    elseif(_filename MATCHES "Elements")
        if(@fetch_package_name@_MULTI_ELEMENTS)
            set(_dllname "ElementsCommon")
        else()
            set(_dllname "Elements")
        endif()
    else()
        set(@fetch_package_name@_FOUND FALSE)
        set(@fetch_package_name@_NOT_FOUND_MESSAGE "Unexpected File '${_filename}'")
        if(NOT @fetch_package_name@_REQUIRED AND NOT @fetch_package_name@_QUIETLY)
            message(WARNING "Unexpected File '${_filename}'")
        endif()
        return()
    endif()

    set(_includedir "${@fetch_package_name@_ROOT_DIR}/include")

    string(REPLACE "/release/" "/debug/" _debugdll ${_releasedll})
    string(REPLACE ".dll" "d.dll" _debugdll ${_debugdll})

    string(REPLACE ".dll" ".lib" _releaselib "${_releasedll}")
    string(REPLACE ".dll" ".lib" _debuglib "${_debugdll}")

    add_library(@fetch_package_name@::${_dllname} SHARED IMPORTED)
    set_target_properties(@fetch_package_name@::${_dllname} PROPERTIES INTERFACE_INCLUDE_DIRECTORIES "${_includedir}")
    set_target_properties(@fetch_package_name@::${_dllname} PROPERTIES
        IMPORTED_CONFIGURATIONS "RELEASE;DEBUG"
        IMPORTED_IMPLIB_RELEASE "${_releaselib}"
        IMPORTED_LOCATION_RELEASE "${_releasedll}"
        IMPORTED_IMPLIB_DEBUG "${_debuglib}"
        IMPORTED_LOCATION_DEBUG "${_debugdll}"
    )

    if(_dllname STREQUAL "Messages")
        set_target_properties(@fetch_package_name@::${_dllname} PROPERTIES INTERFACE_LINK_LIBRARIES "@fetch_package_name@::Elements")
    elseif(NOT _dllname STREQUAL "Elements")
        target_link_libraries(@fetch_package_name@::Elements INTERFACE "@fetch_package_name@::${_dllname}")
        if(NOT _dllname STREQUAL "ElementsCommon")
            set_target_properties(@fetch_package_name@::${_dllname} PROPERTIES INTERFACE_LINK_LIBRARIES "@fetch_package_name@::ElementsCommon")
        endif()
    endif()

    list(APPEND @fetch_package_name@_LIBRARIES "@fetch_package_name@::${_dllname}")
endforeach()

# handle the QUIETLY and REQUIRED arguments and set xxx_FOUND to TRUE if
# all listed variables are TRUE
include(FindPackageHandleStandardArgs)
find_package_handle_standard_args(@fetch_package_name@ DEFAULT_MSG
    @fetch_package_name@_ROOT_DIR @fetch_package_name@_LIBRARIES)
