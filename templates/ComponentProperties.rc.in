#include "winres.h"

#define RCFILE_VERSION             @RCFILE_PROJECT_VERSION@
#define RCFILE_FILE_DESCRIPTION    "Component @RCFILE_COMPONENT_NAME@ of project @RCFILE_PROJECT_NAME@"
#define RCFILE_FILE_VERSION        "@RCFILE_PROJECT_VERSION@ (#@RCFILE_PROJECT_VERSION_HASH@)"
#define RCFILE_PRODUCT_NAME        "@RCFILE_PROJECT_NAME@"
#define RCFILE_PRODUCT_VERSION     "@RCFILE_PROJECT_VERSION@ (#@RCFILE_PROJECT_VERSION_HASH@)"
#define RCFILE_LEGAL_COPYRIGHT     "Copyright (C) 2020-2023 CS GROUP, all rights reserved"

VS_VERSION_INFO VERSIONINFO
FILEVERSION RCFILE_VERSION
PRODUCTVERSION RCFILE_VERSION

BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0" /* 0409 = English, 04B0 = UTF-8 */
        BEGIN
            VALUE "FileDescription", RCFILE_FILE_DESCRIPTION
            VALUE "FileVersion",     RCFILE_FILE_VERSION
            VALUE "ProductName",     RCFILE_PRODUCT_NAME
            VALUE "ProductVersion",  RCFILE_PRODUCT_VERSION
            VALUE "LegalCopyright",  RCFILE_LEGAL_COPYRIGHT
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0 /* 0409 = English, 04B0 = UTF-8 */
    END
END
