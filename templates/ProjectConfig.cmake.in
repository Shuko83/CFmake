@PACKAGE_INIT@

include(${CMAKE_CURRENT_LIST_DIR}/@CMAKE_PROJECT_NAME@Targets.cmake)

set(@CMAKE_PROJECT_NAME@_FOUND TRUE)
set(@CMAKE_PROJECT_NAME@_DIR ${PACKAGE_PREFIX_DIR})
set(@CMAKE_PROJECT_NAME@_INCLUDE_DIR ${PACKAGE_PREFIX_DIR}/include)
set(@CMAKE_PROJECT_NAME@_LIBRARIES @CMAKE_PROJECT_NAME_LIBRARIES@)

foreach(@CMAKE_PROJECT_NAME@_LIBRARY IN LISTS @CMAKE_PROJECT_NAME@_LIBRARIES)
  set_property(TARGET ${@CMAKE_PROJECT_NAME@_LIBRARY} APPEND PROPERTY IMPORTED_CONFIGURATIONS MINSIZEREL RELWITHDEBINFO)
  get_target_property(IMPORTED_LOCATION_RELEASE ${@CMAKE_PROJECT_NAME@_LIBRARY} IMPORTED_LOCATION_RELEASE)
  set_target_properties(${@CMAKE_PROJECT_NAME@_LIBRARY} PROPERTIES
    MAP_IMPORTED_CONFIG_MINSIZEREL RELEASE
    MAP_IMPORTED_CONFIG_RELWITHDEBINFO RELEASE
    IMPORTED_LOCATION_MINSIZEREL ${IMPORTED_LOCATION_RELEASE}
    IMPORTED_LOCATION_RELWITHDEBINFO ${IMPORTED_LOCATION_RELEASE})
endforeach(@CMAKE_PROJECT_NAME@_LIBRARY IN LISTS @CMAKE_PROJECT_NAME@_LIBRARIES)
