qtLessThan( 5.0 ) {

    # -- Force debug informations in release mode for qmake 2.x compatibility -- #

    TEMPLATE( binary ): \
        build_mode( release ) {

            QMAKE_CXXFLAGS *= $${QMAKE_CXXFLAGS_RELEASE_WITH_DEBUGINFO}
            QMAKE_CFLAGS *= $${QMAKE_CFLAGS_RELEASE_WITH_DEBUGINFO}
        }
}
