# -- TO REMOVE: deprecated rules skip target properties rules -- #
!deprecated_rules {
# -- TO REMOVE: deprecated rules skip target properties rules -- #


build_pass( binary ) {

    # -- Target application name and version resolution -- #

    ## PROPERTIES.name = application name (or target name if empty)
    ## PROPERTIES.version = target version (set to unversioned if empty)

    isEmpty( PROPERTIES.name ): \
        PROPERTIES.name = $$TARGET()

    isEmpty( PROPERTIES.version ): \
        PROPERTIES.version = $${VERSION}

    PROPERTIES.version = $$split( PROPERTIES.version, . )

    VER_MAJ = 0
    VER_MIN = 0
    VER_PAT = 0
    VER_BLD = 0
    clear( VERSION )

    ## check PROPERTIES.version format: major[.minor][.patch][.build]

    !isEmpty( PROPERTIES.version ) {

        count( PROPERTIES.version, 1 ): \
            PROPERTIES.version = $${PROPERTIES.version} $${VER_MIN}

        VERSION = $$join( PROPERTIES.version, . )
        VERSION = $$remove( VERSION, ^(?:\\d+(?:\\.\\d+){1,3})$ )

        isEmpty( VERSION ) {

            VERSION = $$join( PROPERTIES.version, . )
            VERSION = $$remove( VERSION, ^(?:0+(?:\\.0+){1,3})$ )
        }

        else {

            qswarning( "Invalid target version '$${PROPERTIES.version}' detected" )
            clear( VERSION )
        }
    }

    ## if PROPERTIES.version is empty, invalid or set to 0[.0][.0][.0]

    isEmpty( VERSION ) {

        VERSION = $${VER_MAJ}
        PROPERTIES.version = unversioned
    }

    ## else normalizes PROPERTIES.version format: major[.minor][.patch][.build]

    else {

        VER_MAJ = $$member( PROPERTIES.version, 0 )
        VER_MIN = $$member( PROPERTIES.version, 1 )

        count( PROPERTIES.version, 2 ): VERSION = $${VERSION}.$${VER_PAT}
        else: VER_PAT = $$member( PROPERTIES.version, 2 )

        count( PROPERTIES.version, 4 ) {

            VER_BLD = $$member( PROPERTIES.version, 3 )
            !win32: VERSION = $${VER_MAJ}.$${VER_MIN}.$${VER_PAT}
        }

        PROPERTIES.version = $$join( PROPERTIES.version, . )
    }

    ## if major, minor, patch or build version number is invalid

    greaterThan( VER_MAJ, 255 )| \
    greaterThan( VER_MIN, 255 )| \
    greaterThan( VER_PAT, 65535 )| \
    greaterThan( VER_BLD, 65535 ) {

        qswarning( "Invalid target version '$${PROPERTIES.version}' detected" )

        VER_MAJ = 0
        VER_MIN = 0
        VER_PAT = 0
        VER_BLD = 0

        VERSION = $${VER_MAJ}
        PROPERTIES.version = unversioned
    }

    PROPERTIES.name = $$quote( $${PROPERTIES.name} )
    PROPERTIES.version = $$quote( $${PROPERTIES.version} )


    # -- Target properties definition -- #

    ## PROPERTIES.product     = product name (or target name if empty)
    ## PROPERTIES.description = target description
    ## PROPERTIES.company     = organization (i.e. company or author) name
    ## PROPERTIES.domain      = internet domain of the organization
    ## PROPERTIES.year        = year of target's first publication (set to year of build if empty)

    isEmpty( PROPERTIES.product ): \
        PROPERTIES.product = $$TARGET()

    isEmpty( PROPERTIES.year ) {

        equals( QMAKE_HOST.os, Linux ): \
            PROPERTIES.year = $$system( "echo $(date +%Y)" )
            
        else: equals( QMAKE_HOST.os, Windows ) {
        
            PROPERTIES.year = $$system( "echo %DATE:~6,4%" )
            
            _resolved = $$remove( PROPERTIES.year, ^[0-9]{4}$ )            
            !isEmpty( _resolved ): PROPERTIES.year = $$system( "echo %DATE:~0,4%" )
            
            unset( _resolved )
        }
    }

    PROPERTIES.product = $$quote( $${PROPERTIES.product} )
    PROPERTIES.description = $$quote( $${PROPERTIES.description} )
    PROPERTIES.company = $$quote( $${PROPERTIES.company} )
    PROPERTIES.domain = $$quote( $${PROPERTIES.domain} )
    PROPERTIES.year = $$quote( $${PROPERTIES.year} )

    isEmpty( PROPERTIES.company ): \
        clear( PROPERTIES.domain )


    # -- Target copyright definition -- #

    ## PROPERTIES.copyright   = copyright pattern with:
    ##                              %c replaced by PROPERTIES.company
    ##                              %y replaced by PROPERTIES.year

    !isEmpty( PROPERTIES.copyright ) {

        PROPERTIES.copyright = $$quote( $${PROPERTIES.copyright} )
        PROPERTIES.copyright = $$replace( PROPERTIES.copyright, %c, $${PROPERTIES.company} )
        PROPERTIES.copyright = $$replace( PROPERTIES.copyright, %y, $${PROPERTIES.year} )
    }


    # -- Target properties generation -- #

    no_generated_target_info: \
        CONFIG *= no_builtin_target_properties

    !no_builtin_target_properties {

        ## header generation from template qs_target_info.h

        _target_info = $$quote( $$cat( $${PWD}/../templates/qs_target_info.h, blob ) )
        _target_info = $$replace( _target_info, $$escape_expand( \\r\\n ), $$escape_expand( \\n ) )

        !TEMPLATE( app )|!qt: \
            _target_info = $$remove( _target_info, $$re_escape( {{QT_APPLICATION}} )(?:(?!$$re_escape( {{QT_APPLICATION}} )).)*$$re_escape( {{QT_APPLICATION}} )[ ]*$$escape_expand( \\n ) )

        qtGreaterThan( 5.1, true ): _target_info = $$remove( _target_info, $$re_escape( {{QT_LESS_THAN_5_1}} )(?:(?!$$re_escape( {{QT_LESS_THAN_5_1}} )).)*$$re_escape( {{QT_LESS_THAN_5_1}} )[ ]*$$escape_expand( \\n ) )
        else: _target_info = $$remove( _target_info, $$re_escape( {{QT_GREATER_THAN_5_1}} )(?:(?!$$re_escape( {{QT_GREATER_THAN_5_1}} )).)*$$re_escape( {{QT_GREATER_THAN_5_1}} )[ ]*$$escape_expand( \\n ) )

        _target_info = $$remove( _target_info, $$re_escape( {{ )\\w+$$re_escape( }} )[ ]*$$escape_expand( \\n ) )

        _target_info = $$replace( _target_info, $$re_escape( {{QMAKE_VERSION}} ), $$[QMAKE_VERSION] )
        _target_info = $$replace( _target_info, $$re_escape( {{QT_VERSION}} ), $$[QT_VERSION] )

        _target_cpp = $$TARGET()
        _target_cpp = $$replace( _target_cpp, $$re_escape( - ), _ )

        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_INCGUARD}} ), $$upper( $${_target_cpp} ) )
        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_NAMESPACE}} ), $${_target_cpp} )

        write_file( $${_PRO_FILE_PWD_}/$${TARGETINFO_DIR}/info_$$TARGET().h, _target_info )

        ## source generation from template qs_target_info.cpp

        _target_info = $$quote( $$cat( $${PWD}/../templates/qs_target_info.cpp, blob ) )
        _target_info = $$replace( _target_info, $$escape_expand( \\r\\n ), $$escape_expand( \\n ) )

        !TEMPLATE( app )|!qt: \
            _target_info = $$remove( _target_info, $$re_escape( {{QT_APPLICATION}} )(?:(?!$$re_escape( {{QT_APPLICATION}} )).)*$$re_escape( {{QT_APPLICATION}} )[ ]*$$escape_expand( \\n ) )

        qtGreaterThan( 5.1, true ): _target_info = $$remove( _target_info, $$re_escape( {{QT_LESS_THAN_5_1}} )(?:(?!$$re_escape( {{QT_LESS_THAN_5_1}} )).)*$$re_escape( {{QT_LESS_THAN_5_1}} )[ ]*$$escape_expand( \\n ) )
        else: _target_info = $$remove( _target_info, $$re_escape( {{QT_GREATER_THAN_5_1}} )(?:(?!$$re_escape( {{QT_GREATER_THAN_5_1}} )).)*$$re_escape( {{QT_GREATER_THAN_5_1}} )[ ]*$$escape_expand( \\n ) )

        _target_info = $$remove( _target_info, $$re_escape( {{ )\\w+$$re_escape( }} )[ ]*$$escape_expand( \\n ) )

        _target_info = $$replace( _target_info, $$re_escape( {{QMAKE_VERSION}} ), $$[QMAKE_VERSION] )
        _target_info = $$replace( _target_info, $$re_escape( {{QT_VERSION}} ), $$[QT_VERSION] )
        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_INCLUDE}} ), $$TARGET() )
        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_NAMESPACE}} ), $${_target_cpp} )

        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_NAME}} ), $${PROPERTIES.name} )
        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_VERSION}} ), $${PROPERTIES.version} )
        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_PRODUCT}} ), $${PROPERTIES.product} )
        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_ORGANIZATION}} ), $${PROPERTIES.company} )
        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_DOMAIN}} ), $${PROPERTIES.domain} )

        _target_info = $$replace( _target_info, $$re_escape( {{TARGET_COPYRIGHT}} ), $${PROPERTIES.copyright} )
        _target_info = $$replace( _target_info, $$re_escape( (C) ), \\xC2\\xA9 )

        write_file( $${_PRO_FILE_PWD_}/$${TARGETINFO_DIR}/info_$$TARGET().cpp, _target_info )

        ## generated sources registration

        IQUOTEPATH *= $${TARGETINFO_DIR}
        GENERATED_SOURCES *= $${TARGETINFO_DIR}/info_$$TARGET().cpp

        ## generated sources cleaning

        QMAKE_DISTCLEAN *= $${_PRO_FILE_PWD_}/$${TARGETINFO_DIR}/info_$$TARGET().h \
                           $${_PRO_FILE_PWD_}/$${TARGETINFO_DIR}/info_$$TARGET().cpp

        unset( _target_cpp )
        unset( _target_info )
    }
}


}
