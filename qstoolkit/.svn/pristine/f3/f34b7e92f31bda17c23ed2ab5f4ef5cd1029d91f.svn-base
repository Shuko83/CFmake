msvc-proj: \
build_pass( aux ) {

    # -- Output directory (Visual C++ projects only) -- #

    ## _generated_dir = Visual C++ generated files path: generated/$${TOOLKIT.mkspec}

    _generated_dir = $$clean_path( generated/$${TOOLKIT.mkspec} )

    ## OBJECTS_DIR     = object files path: $${_generated_dir}
    ## PRECOMPILED_DIR = precompiled headers path: $${_generated_dir}
    ## DESTDIR         = target output path: $${_generated_dir}

    OBJECTS_DIR = $${_generated_dir}
    PRECOMPILED_DIR = $${_generated_dir}
    DESTDIR = $${_generated_dir}
}


# -- TO REMOVE: deprecated rules skip compiler outputs rules -- #
!deprecated_rules {
# -- TO REMOVE: deprecated rules skip compiler outputs rules -- #


build_pass( binary ) {

    # -- Intermediate directories -- #

    ## _intermediate_dir = intermediate generated files path: generated/$${TOOLKIT.mkspec}/$${LIBRARY_MODE}/$${BUILD_MODE}

    _intermediate_dir = $$clean_path( generated/$${TOOLKIT.mkspec}/$${LIBRARY_MODE}/$${BUILD_MODE} )

    ## TARGETINFO_DIR  = target properties path: $${_intermediate_dir}/info
    ## OBJECTS_DIR     = object files path: $${_intermediate_dir}/obj
    ## PRECOMPILED_DIR = precompiled headers path: $${_intermediate_dir}/pch
    ## MOC_DIR         = moc files path: $${_intermediate_dir}/moc
    ## RCC_DIR         = rcc files path: $${_intermediate_dir}/qrc
    ## UI_DIR          = uic files path: $${_intermediate_dir}/uic

    TARGETINFO_DIR = $${_intermediate_dir}/info
    OBJECTS_DIR = $${_intermediate_dir}/obj
    PRECOMPILED_DIR = $${_intermediate_dir}/pch
    MOC_DIR = $${_intermediate_dir}/moc
    RCC_DIR = $${_intermediate_dir}/qrc
    UI_DIR = $${_intermediate_dir}/uic

    unset( _intermediate_dir )


    # -- Output directory -- #

    ## _output_dir = built output files path: $${DESTDIR} or $${DLLDESTDIR} (shared library on Windows platforms only) relative to project path in use
    ##             = builds/$${TOOLKIT.mkspec}/$${LIBRARY_MODE}/$${BUILD_MODE} if DESTDIR or DLLDESTDIR not defined

    !isEmpty( DLLDESTDIR ) {

        win32: TEMPLATE( shared ) {

            _output_dir = $$relative_path( $${DLLDESTDIR}, $${_PRO_FILE_PWD_} )

            isEmpty( DESTDIR ) {

                DESTDIR = $${_output_dir}
                clear( DLLDESTDIR )
            }

            else {

                DESTDIR = $$relative_path( $${DESTDIR}, $${_PRO_FILE_PWD_} )
                DLLDESTDIR = $${_output_dir}
            }
        }

        else: clear( DLLDESTDIR )
    }

    isEmpty( _output_dir ) {

        isEmpty( DESTDIR ): _output_dir = $$clean_path( builds/$${TOOLKIT.mkspec}/$${LIBRARY_MODE}/$${BUILD_MODE} )
        else: _output_dir = $$relative_path( $${DESTDIR}, $${_PRO_FILE_PWD_} )

        DESTDIR = $${_output_dir}
    }


    # -- Program databases (Visual C++ compiler only) --  #

    msvc {

        TEMPLATE( static ) {

            ## objects program database file path (static library only): $${_output_dir}/$${TARGET}.pdb

            QMAKE_PDBFLAG_DEBUG = -Fd$$system_path( $${_output_dir}/$$TARGET( debug ).pdb )
            QMAKE_PDBFLAG_RELEASE_WITH_DEBUGINFO = -Fd$$system_path( $${_output_dir}/$$TARGET( release ).pdb )
        }

        else {

            ## objects program databases file path (except for static library): $${OBJECTS_DIR}/$${TARGET}.obj.pdb
            ## binary program databases file path (except for static library): $${_output_dir}/$${TARGET}.pdb

            QMAKE_PDBFLAG_DEBUG = -Fd$$system_path( $${OBJECTS_DIR}/$$TARGET( debug ).obj.pdb )
            QMAKE_PDBFLAG_RELEASE_WITH_DEBUGINFO = -Fd$$system_path( $${OBJECTS_DIR}/$$TARGET( release ).obj.pdb )

            QMAKE_LFLAGS_DEBUG *= /PDB:$$system_path( $${_output_dir}/$$TARGET( debug ).pdb )
            QMAKE_LFLAGS_RELEASE_WITH_DEBUGINFO *= /PDB:$$system_path( $${_output_dir}/$$TARGET( release ).pdb )
        }

        ## C++ compiler flags

        QMAKE_CXXFLAGS_DEBUG *= $${QMAKE_PDBFLAG_DEBUG}
        QMAKE_CXXFLAGS_RELEASE_WITH_DEBUGINFO *= $${QMAKE_PDBFLAG_RELEASE_WITH_DEBUGINFO}

        ## C compiler flags

        QMAKE_CFLAGS_DEBUG *= $${QMAKE_PDBFLAG_DEBUG}
        QMAKE_CFLAGS_RELEASE_WITH_DEBUGINFO *= $${QMAKE_PDBFLAG_RELEASE_WITH_DEBUGINFO}
    }
}


}
