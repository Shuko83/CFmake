# -- function: append_line( [string] ) -- #

defineTest( append_line ) {

    isEmpty( ARGS ): _filestream += " "
    else: _filestream += $$quote( $${1} )

    export( _filestream )
    return( true )
}

# -- function: append_string( string ) -- #

defineTest( append_string ) {

    arg.string = $${1}

    !isEmpty( arg.string ) {

        _filestream = $${_filestream}$$quote( $${arg.string} )
        export( _filestream )
    }

    return( true )
}

# -- function: on_writer_start() -- #

defineTest( on_writer_start ) {

    contains( _writerstate, start ): \
        return( true )

    return( false )
}

# -- function: on_writer_end() -- #

defineTest( on_writer_end ) {

    contains( _writerstate, end ): \
        return( true )

    return( false )
}

# -- function: write_lines( filename[, mode] ) -- #

defineTest( write_lines ) {

    arg.filename = $${1}
    arg.mode = $${2}

    !isEmpty( arg.filename ): \
	!isEmpty(_filestream ){

        write_file( $${arg.filename}, _filestream, $${arg.mode} )
        return( true )
    }

    return( false )
}


# -- Metadata generators processing -- #

# -- TO REMOVE: deprecated rules skip metadata generators processing -- #
!deprecated_rules {
# -- TO REMOVE: deprecated rules skip metadata generators processing -- #


for( metadata, METADATA ): \
    contains( QMAKE_METADATA_GENERATORS, $${metadata} ) {

        ## enables metadata generation according to generator features and current build mode

        _processable = true

        TEMPLATE( binary ): \
        !isEmpty( $${metadata}.CONFIG ) {

            contains( $${metadata}.CONFIG, release ) {

                !build_mode( release ): _processable = false
                static_and_shared: !build_pass(): _processable = true
            }

            else: contains( $${metadata}.CONFIG, debug ) {

                !build_mode( debug ): _processable = false
                static_and_shared: !build_pass(): _processable = true
            }
        }

        ## executes metadata generator if enabled

        equals( _processable, true ) {

            !exists( $$eval( $${metadata}.template ) ): \
                qswarning( "'$${metadata}' metadata generator not found" )

            else {

                clear( _writerstate )
                clear( _filestream )

                # resolves - first/last build modes if debug_and_release option is set
                #          - first/last library modes if static_and_shared option is set

                qtLessThan( 5.2 ) {

                    _build_mode.first = release
                    _build_mode.last  = debug

                    _library_mode.first = shared
                    _library_mode.last  = static
                }

                else {

                    _build_mode.first = debug
                    _build_mode.last  = release

                    _library_mode.first = static
                    _library_mode.last  = shared
                }

                # detects start/end write processing
                # if debug_and_release mode disabled in generator features or Qt configurations

                !debug_and_release| \
                contains( $${metadata}.CONFIG, debug|release ) {

                    !static_and_shared: \
                        _writerstate = start end

                    else {

                        TEMPLATE( $${_library_mode.first} ):      _writerstate = start
                        else: TEMPLATE( $${_library_mode.last} ): _writerstate = end
                    }
                }

                # detects start/end write processing
                # if debug_and_release mode enabled in generator features and Qt configurations

                else {

                    build_mode( $${_build_mode.first} ) {

                        !static_and_shared| \
                        TEMPLATE( $${_library_mode.first} ): \
                            _writerstate = start
                    }

                    else: build_mode( $${_build_mode.last} ) {

                        !static_and_shared| \
                        TEMPLATE( $${_library_mode.last} ): \
                            _writerstate = end
                    }
                }

                unset( _build_mode.first )
                unset( _build_mode.last )
                unset( _library_mode.first )
                unset( _library_mode.last )

                # processes metadata generator

                include( $$eval( $${metadata}.template ) )

                on_writer_start(): write_lines( $$eval( $${metadata}.target ) )
                else: write_lines( $$eval( $${metadata}.target ), append )
            }
        }
    }


}

unset( _processable )
unset( _writerstate )
unset( _filestream )
