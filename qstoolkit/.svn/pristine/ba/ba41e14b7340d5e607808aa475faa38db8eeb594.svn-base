include($ENV{QMAKEPATH}/cmake/qstoolkit_nonqt.cmake)

execute_process(COMMAND qmake -query QT_VERSION OUTPUT_VARIABLE QT_VERSION)

if(QT_VERSION)

    string(STRIP ${QT_VERSION} QT_VERSION)
	
	string(REPLACE "." ";" qt_version_numbers ${QT_VERSION})
	list(GET qt_version_numbers 0 QT_MAJOR_VERSION)
	list(GET qt_version_numbers 1 QT_MINOR_VERSION)
	list(GET qt_version_numbers 2 QT_PATCH_VERSION)
	
	set(QT_VERSION_MM ${QT_MAJOR_VERSION}.${QT_PATCH_VERSION})
    
    file(WRITE ${CMAKE_CURRENT_BINARY_DIR}/dummy.pro)
    execute_process(COMMAND qmake QUERY_TOOLKIT_PROPERTY=mkspec ${CMAKE_CURRENT_BINARY_DIR}/dummy.pro ERROR_VARIABLE QMAKE_MKSPEC)
    file(REMOVE ${CMAKE_CURRENT_BINARY_DIR}/dummy.pro)
    
    if(QMAKE_MKSPEC)
    
        string(STRIP ${QMAKE_MKSPEC} QMAKE_MKSPEC)

        if(NOT "${QMAKE_MKSPEC}" STREQUAL "${QS_TOOLKIT_MKSPEC}")
            message(FATAL_ERROR "QT makespec mismatch detected")
        endif()
        
        unset(QMAKE_MKSPEC)
        
    else()
        message(FATAL_ERROR "QT makespec cannot be resolved")
    endif()
    
else()
    message(FATAL_ERROR "QT version cannot be resolved")
endif()
