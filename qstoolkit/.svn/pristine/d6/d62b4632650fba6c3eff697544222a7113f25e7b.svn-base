TEMPLATE( aux ) {

    # -- Auxiliary files registration                -- #
    # -- (available on qmake 2.01 (Qt4.8) and later) -- #

    ## OTHER_FILES = registers auxiliary files as other files
    ## DISTFILES     or distribution files (Visual C++ projects only)

    msvc-proj {

        DISTFILES *= $${HEADERS}                                            # registers header files as distribution files
        DISTFILES *= $${SOURCES}                                            # registers C/C++ source files as distribution files
        DISTFILES *= $${LEXSOURCES} $${YACCSOURCES}                         # registers Lex/Yacc source files as distribution files
        DISTFILES *= $${QML_FILES}                                          # registers QML files as distribution files
        DISTFILES *= $${FORMS}                                              # registers form files as distribution files
        DISTFILES *= $${TRANSLATIONS}                                       # registers translation files as distribution files
    }

    else {

        OTHER_FILES *= $${HEADERS}                                          # registers header files as other files
        OTHER_FILES *= $${SOURCES}                                          # registers C/C++ source files as other files
        OTHER_FILES *= $${LEXSOURCES} $${YACCSOURCES}                       # registers Lex/Yacc source files as other files
        OTHER_FILES *= $${QML_FILES}                                        # registers QML files as other files
        OTHER_FILES *= $${FORMS}                                            # registers form files as other files
        OTHER_FILES *= $${TRANSLATIONS}                                     # registers translation files as other files
    }

    clear( HEADERS )
    clear( SOURCES )
    clear( LEXSOURCES )
    clear( YACCSOURCES )
    clear( QML_FILES )
    clear( FORMS )
    clear( RESOURCES )
    clear( TRANSLATIONS )
}


TEMPLATE( binary ) {

    # -- QML files registration                     -- #
    # -- (available on qmake 3.0 (Qt5.0) and later) -- #

    ## QML_FILES = QML files included in the project

    qtGreaterThan( 5.0, true ): \
        !isEmpty( QML_FILES ) {

            msvc-proj: DISTFILES *= $${QML_FILES}                           # registers QML files as other files
            else: OTHER_FILES *= $${QML_FILES}                              # or distribution files (Visual C++ projects only)

            QML_IMPORT_PATH *= $$[QT_INSTALL_QML]                           # add QML 2.x extensions in QML import path
        }
}


build_pass( binary ) {

    # -- C++ preprocessor macros definition -- #

    # -- TO REMOVE: deprecated rules skip C++ preprocessor macros definitions -- #
    !deprecated_rules {
    # -- TO REMOVE: deprecated rules skip C++ preprocessor macros definitions -- #


    DEFINES = $$unique( DEFINES )
    build_mode( release ): DEFINES *= NDEBUG                                # disables assertions in release mode

    win32 {

        DEFINES *= _WIN32                                                   # standard Windows 32/64 bits platform preprocessor macro
        equals( TOOLKIT.host.arch, x64 ): DEFINES *= _WIN64                 # standard Windows 64 bits platform preprocessor macro

        contains( DEFINES, _MBCS ): DEFINES -= UNICODE _UNICODE             # enables multi-byte characters set if predefined
        else:                       DEFINES *= UNICODE _UNICODE             # otherwise enables Unicode characters set by default

        DEFINES *= _USE_MATH_DEFINES                                        # enables mathematical constants defined in C/C++ math headers
        DEFINES *= WIN32_LEAN_AND_MEAN                                      # excludes APIs such as Cryptography, DDE, RPC, Shell, and Windows Sockets
    }

    else: linux: DEFINES *= __linux__                                       # standard Linux platform preprocessor macro


    }


    # -- Include directories definition -- #

    IQUOTEPATH = $$unique( IQUOTEPATH )
    INCLUDEPATH = $$unique( INCLUDEPATH )

    msvc: \
        INCLUDEPATH *= $${IQUOTEPATH}

    else: gcc {

        QMAKE_CXXFLAGS *= $$prepend( IQUOTEPATH, -iquote )                  # add search dir only for header files requested with quoted include
        QMAKE_CFLAGS   *= $$prepend( IQUOTEPATH, -iquote )                  # header files requested with '#include <file>' will be ignored
    }


    # -- Static libraries dependencies -- #

    resolve_debug_modifiers( PRE_TARGETDEPS )
    resolve_debug_modifiers( POST_TARGETDEPS )


    # -- Archiver entries definition -- #

    ## COMBINED_LIBS = list of static libraries combined to this target (static library only)
    ## LIBRARYPATH = list of search directories for combined libraries

    TEMPLATE( static ) {

        resolve_debug_modifiers( COMBINED_LIBS )

        for( library, COMBINED_LIBS ): \
            LIBRARYPATH *= $$relative_path( $$dirname( library ), $${_PRO_FILE_PWD_} )

        clear( LIBRARYPATH )
        clear( LIBS )
    }


    # -- Linker entries definition -- #

    ## LIBRARYPATH = list of search directories for linked libraries

    else {

        LIBS *= $$prepend( LIBRARYPATH, -L )

        resolve_debug_modifiers( LIBS )

        LIBRARYPATH = $$find( LIBS, ^-L.* )
        LIBRARYPATH = $$unique( LIBRARYPATH )

        _libraries = $${LIBS}
        _libraries -= $${LIBRARYPATH}

        LIBS = $${LIBRARYPATH}
        LIBRARYPATH = $$remove( LIBRARYPATH, ^-L )

        win32 {

            LIBS += $${_libraries}

            for( library, _libraries ) {

                !startsWith( library, -l ): \
                    LIBRARYPATH *= $$relative_path( $$dirname( library ), $${_PRO_FILE_PWD_} )
            }
        }

        else {

            for( library, _libraries ) {

                !startsWith( library, -l ) {

                    libpath = $$relative_path( $$dirname( library ), $${_PRO_FILE_PWD_} )

                    LIBS *= -L$${libpath}
                    LIBRARYPATH *= $${libpath}
                }
            }

            for( library, _libraries ) {

                startsWith( library, -l ): LIBS += $${library}
                else: LIBS += -l$$basename( library )
            }
        }

        clear( COMBINED_LIBS )
        unset( _libraries )
    }


    # -- Plugin entries definition -- #

    ## PLUGINPATH = list of search directories for libraries dynamically loadable at runtime

    PLUGINS = $$unique( PLUGINS )

    resolve_debug_modifiers( PLUGINS )

    for( plugin, PLUGINS ): \
        PLUGINPATH *= $$relative_path( $$dirname( plugin ), $${_PRO_FILE_PWD_} )
}
