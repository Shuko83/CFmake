## BOOST_ROOT    = Boost root path: BOOST_ROOT environment variable value
## BOOST_VERSION = Boost version (deduced from version.hpp header)

BOOST_ROOT = $$clean_path( $$(BOOST_ROOT) )

!isEmpty( BOOST_ROOT ) {

    # -- Windows 32/64 bits MSVC environment -- #

    ## BOOST_INCLUDEDIR = Boost's headers path: $${BOOST_ROOT}
    ## BOOST_LIBRARYDIR = Boost libraries path: $${BOOST_ROOT}/lib[32|64]-msvc-$${MSVC_VER}

    win32: msvc {

        ## Directories resolution
    
        BOOST_INCLUDEDIR = $${BOOST_ROOT}
        BOOST_LIBRARYDIR = $${BOOST_ROOT}

        equals( TOOLKIT.host.arch, x86 ):       BOOST_LIBRARYDIR = $${BOOST_LIBRARYDIR}/lib32
        else: equals( TOOLKIT.host.arch, x64 ): BOOST_LIBRARYDIR = $${BOOST_LIBRARYDIR}/lib64

        BOOST_LIBRARYDIR = $$clean_path( $${BOOST_LIBRARYDIR}-msvc-$${MSVC_VER} )

        ## Version resolution
        
        _boost_version = $$system( "find \"$${LITERAL_HASH}define BOOST_VERSION\" $${BOOST_INCLUDEDIR}/boost/version.hpp" )
        _boost_version = $$find( _boost_version, \\d+$ )
        
        !isEmpty( _boost_version ) {
        
            BOOST_VERSION = $$system( "find \"$${LITERAL_HASH}define BOOST_LIB_VERSION\" $${BOOST_INCLUDEDIR}/boost/version.hpp" )
            BOOST_VERSION = $$find( BOOST_VERSION, \"\\d+_\\d+(?:_\\d+)?\"$ )

            isEmpty( BOOST_VERSION ): \
                unset( _boost_version )

            else {
            
                BOOST_VERSION = $$replace( BOOST_VERSION, _, . )
                BOOST_VERSION = $$remove( BOOST_VERSION, \" )
            }
        }
        
        isEmpty( _boost_version ): \
            _boost_version = 0

        ## Libraries suffix resolution
        
		BOOST_LIBS_SUFFIX = vc$$remove( MSVC_VER, $$re_escape( . ) )
        BOOST_LIBS_SUFFIX = $${BOOST_LIBS_SUFFIX}-mt-

        build_mode( debug ): \
            BOOST_LIBS_SUFFIX = $${BOOST_LIBS_SUFFIX}gd-

        !lessThan( _boost_version, 106600 ) {
        
            equals( TOOLKIT.host.arch, x86 ):       BOOST_LIBS_SUFFIX = $${BOOST_LIBS_SUFFIX}x32-
            else: equals( TOOLKIT.host.arch, x64 ): BOOST_LIBS_SUFFIX = $${BOOST_LIBS_SUFFIX}x64-
        }
        
        BOOST_LIBS_SUFFIX = $${BOOST_LIBS_SUFFIX}$$replace( BOOST_VERSION, $$re_escape( . ), _ )
        
        unset( _boost_version )
    }


    # -- Unsupported environments -- #

    else: unset( BOOST_ROOT )
}
