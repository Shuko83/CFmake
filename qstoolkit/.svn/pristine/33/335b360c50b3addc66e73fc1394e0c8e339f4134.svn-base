# -- function: qsmessage( string ) -- #

defineTest( qsmessage ) {

    arg.string = $${1}

    message( "in $$basename( _PRO_FILE_ ): $${arg.string}" )
    return( true )
}

# -- function: qswarning( string ) -- #

defineTest( qswarning ) {

    arg.string = $${1}

    warning( "in $$basename( _PRO_FILE_ ): $${arg.string}" )
    return( true )
}

# -- function: qsdeprecated( string ) -- #

defineTest( qsdeprecated ) {

    arg.string = $${1}

    log( "Project DEPRECATED: in $$basename( _PRO_FILE_ ): $$escape_expand( $${arg.string}\\n )" )
    return( true )
}

# -- function: qserror( string ) -- #

defineTest( qserror ) {

    arg.string = $${1}

    error( "in $$basename( _PRO_FILE_ ): $${arg.string}" )
    return( true )
}
