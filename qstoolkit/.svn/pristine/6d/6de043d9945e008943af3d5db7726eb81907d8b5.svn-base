/*!
    \page mkspecs-manual.html
    \title qmake Features
    \startpage {mkspecs-manual.html}{QS qmake Features}
    \nextpage Predefined Rules    

    
    \section1 Overview
    
    This set of features extends default qmake features, in order to simplify and unify the 
    generation of development projects across different platforms and build environments. The 
    following table lists configurations supported by these features.
    
    \section3 Qt 4.x

    \table 95%
    \header
        \li Platform
        \li Compiler
        \li qmake Platform and Compilers Scope
    \header
        \li {3, 1} Desktop Platforms
    \row
        \li Windows 7 \br (32 and 64-bit)
        \li MSVC 2010, MSVC 2008 \br
            MinGW 4.4
        \li \e {plaftorm:} \c {win32} \br
            \e {compiler:} \c {msvc}, \c {msvc-proj}, \c {mingw}, \c {gcc}
    \row
        \li Linux / X11 \br (32 and 64-bit)
        \li GCC 4.2 and above
        \li \e {plaftorm:} \c {linux}, \c {gnu} \br
            \e {compiler:} \c {gcc}
    \endtable
    
    \section3 Qt 5.x
    
    \table 95%
    \header
        \li Platform
        \li Compiler
        \li qmake Platform and Compilers Scope
    \header
        \li {3, 1} Desktop Platforms
    \row
        \li Windows 7 and later \br (32 and 64-bit)
        \li MSVC 2015, MSVC 2013, MSVC 2012, MSVC 2010 \br
            MinGW 4.7 and above
        \li \e {plaftorm:} \c {win32} \br
            \e {compiler:} \c {msvc}, \c {msvc-proj}, \c {mingw}, \c {gcc}
    \row
        \li Linux / X11 \br (32 and 64-bit)
        \li GCC 4.8 and above
        \li \e {plaftorm:} \c {linux}, \c {gnu} \br
            \e {compiler:} \c {gcc}
    \row
        \li {3, 1}
    \header
        \li {3, 1} Mobile Platforms
    \row
        \li Android \br (x86, armv5, armv7)
        \li GCC 4.8 and above (provided by Android NDK) \br
            \e {Toolchain:} Windows MinGW
        \li \e {plaftorm:} \c {mobile}, \c {android}, \c {linux} \br
            \e {compiler:} \c {gcc}
    \endtable

    \note QS features requires \b {qmake 2.01a (Qt 4.7)} or later to be processed.


    \section1 Installation

    QS features directory location is free. To be taken into account by qmake tool, just set 
    \c {QMAKEPATH} environment variable to qstoolkit directory path.
    

    \section1 Table of Contents
    
    \list
        \li \l {Predefined Rules}
        \li \l {Metadata Generation}
        \li \l {Reference}
        \list
            \li \l {Variables}
            \li \l {Pseudo Variables}
            \li \l {Replace Functions}
            \li \l {Test Functions}
        \endlist
    \endlist    
*/


/*!
    \page mkspecs-predefined-rules.html
    \title Predefined Rules
    \previouspage qmake Features
    \nextpage Metadata Generation
    
    
    \section1 Default Qt Configurations
    
    QS features overrides default project configuration and compiler options defined by qmake 
    mkspecs. Below a description of \c {CONFIG} values that are predefined:
    
    \table
    \header
        \li {2, 1} Option
        \li Description
    \header
        \li {3, 1} Build Modes
    \row
        \li \c {-}
        \li \c {debug_and_release}
        \li Project built in both debug and release modes. When enabling this option:
            
            \list
                \li \e {from Qt 5.2:} \c {debug_and_release} option will be deactivated if \c 
                    {CONFIG} option \c {debug} or \c {release} is set through qmake arguments.
                \li debug and release builds end up in separate debug and release directories 
                    (\c {debug_and_release_target} option automatically set).
            \endlist
    \row
        \li \c {+}
        \li
        \li By default, \c {debug_and_release} mode is activated only for Visual C++ projects.
    \row
        \li \c {-}
        \li \c {build_all}
        \li Disables project built in both debug and release modes by default.
    \row        
        \li \c {-}
        \li \c {static_and_shared}
        \li \e {Library target only:} project built in both static and shared versions. When 
            enabling this option:
            
            \list
                \li \e {from Qt 5.2:} \c {static_and_shared} option will be deactivated if 
                    \c {CONFIG} option \c {static}, \c {staticlib}, \c {shared}, \c {dll} or 
                    \c {dylib} is set through qmake arguments.
                \li static and shared builds end up in separate static and shared directories.
            \endlist
    \row
        \li {3, 1}
    \header
        \li {3, 1} Compiler Versions
    \row
        \li \c {+}
        \li \c {c++11}
        \li \e {From Qt 5.0:} enables C++11 support.
    \row
        \li \c {-}
        \li \c {c++14}
        \li \e {From Qt 5.4:} disables C++14 support.
    \row
        \li {3, 1}
    \header
        \li {3, 1} Compiler Options
    \row
        \li \c {+}
        \li \c {warn_on}
        \li Compiler prints as many warnings as possible.
    \row
        \li \c {+}
        \li \c {exceptions}
        \li Enables exception support.
    \row
        \li \c {+}
        \li \c {rtti}
        \li Enables RTTI support.
    \row
        \li \c {+}
        \li \c {stl}
        \li Enables STL support.
    \row
        \li \c {+}
        \li \c {thread}
        \li Enables threads support.
    \row
        \li \c {+}
        \li \c {no_include_pwd}
        \li Omits project directory from include paths.
    \row
        \li \c {+}
        \li \c {depend_includepath}
        \li Appends the value of \c {INCLUDEPATH} to \c {DEPENDPATH}.
    \row
        \li \c {-}
        \li \c {lex} \br
            \c {yacc}
        \li Disables Lex and Yacc supports.
    \row
        \li \c {-}
        \li \c {precompile_header}
        \li Disables precompiled headers support.
    \row
        \li \c {-}
        \li \c {no_lflags_merge}
        \li Ensures \c {LIBS} variable to be reduced to a list of unique libraries.
    \row
        \li \c {-}
        \li \c {force_debug_info}
        \li Disables release with debug info mode.
    \row
        \li {3, 1}
    \header
        \li {3, 1} Static Libraries Dependencies
    \row
        \li \c {-}
        \li \c {create_prl}
        \li Deactivates static libraries qmake tracking.
    \row
        \li {3, 1}
    \header
        \li {3, 1} Windows Specific Features
    \row
        \li \c {+}
        \li \c {embed_manifest_dll}
        \li Embeds a manifest file in the .dll created as part of a library project.
    \row
        \li \c {+}
        \li \c {embed_manifest_exe}
        \li Embeds a manifest file in the .exe created as part of an application project.
    \row
        \li \c {-}
        \li \c {flat}
        \li \e {Visual C++ projects only:} groups the files within the source / header group 
            depending on the directory they reside.
    \row
        \li \c {-}
        \li \c {incremental}
        \li \e {Visual C++ compiler only:} disables incremental linking.
    \row
        \li {3, 1}
    \header
        \li {3, 1} Linux Specific Features
    \row
        \li \c {+}
        \li \c {largefile}
        \li Includes support for large files.
    \row
        \li \c {-}
        \li \c {separate_debug_info}
        \li Deactivates debugging information for applications / shared libraries in separate files.
    \endtable
    
    
    \section1 Additional Features
    
    QS features also provides following \c {CONFIG} additional features:
    
    \table
    \header
        \li Option
        \li Description
    \row
        \li \c {boost}
        \li Enables Boost support.
    \row
        \li \c {build_and_install}
        \li \e {Visual C++ projects only:} enables post generation installation step.
    \row
        \li \c {no_generate_project}
        \li Inhibits qmake outputs generation.
    \row
        \li \c {no_literals_cast}
        \li Disables automatic casts between \c {QString} / \c {QByteArray} objects and string 
            literals.          
    \row
        \li \c {no_pass_traces}
        \li Inhibits qmake generation pass traces.
    \row
        \li \c {mkspec_makefile}
        \li Suffixes generated project / makefile with current toolkit mkspec shortname.
    \row
        \li \c {utf8}
        \li Specifies both the source and execution character sets as UTF-8. \br\br
            \b {\e {Visual C++ compiler note:}}
            \list
                \li resource file codepage will be set to Unicode UTF-8.
                \li MSVC 2013 and previous versions only support execution character set.
            \endlist
    \endtable
    
    \section3 Boost Support

    In order to build a project using Boost libraries, following steps are required:
    
    \list
        \li set \c {BOOST_ROOT} environment variable to Boost root directory path.
        \li add \c {CONFIG} \c {+=} \c {boost} in your project file to enable Boost support.
    \endlist
    
    Then, header-only Boost libraries will be automatically accessible from your project. Moreover, 
    if you want to use any of the separately-compiled Boost libraries, uses \l {BOOST} variable to 
    specify the list of modules which will be linked to the target.
    
    For example:

    \snippet doc_src_mkspecs-manual.pro  BOOST rules

    The following table lists configurations supported by this feature.
    
    \table
    \header
        \li Platform
        \li Compiler
        \li Notes
    \header
        \li {3, 1} Desktop Platforms
    \row
        \li \span {class=nowrap} {Windows 7 and later} \br (32 and 64-bit)
        \li MSVC 2015, MSVC 2013, MSVC 2012, MSVC 2010, MSVC 2008
        \li Requires prebuilt Windows binaries installer. \br
            \span {class=nowrap} {\l {https://sourceforge.net/projects/boost/files/boost-binaries}}
    \endtable    
    
    
    \section1 Project Building

    \section3 Target Definition

    Specifies the name of the target with \c {TARGET} variable. For binary targets, optional debug 
    modifiers can be applied to this name by using \c {[...]} patterns.
    
    For example, project below will generate \c {MyAppd} application in debug mode, and \c {MyApp} 
    application in release mode:

    \snippet doc_src_mkspecs-manual.pro  TARGET rules
    
    Following target features will be automatically applied, according to project type:

    \table
    \header
        \li \span {class=nowrap} {Project Type}
        \li \c {CONFIG} Flags
        \li Description
    \row
        \li {1, 2} \span {class=nowrap} {subdirs-based}
        \li \c {no_empty_targets}
        \li Project doesn't have targets that do nothing.
    \row
        \li \c {ordered}
        \li \e {Visual C++ projects only:} force directories listed to be processed in the order in 
            which they are given. From \b {qmake 3.0 (Qt 5.4.1)}, this feature has been given up in 
            favour of \c {SUBDIRS} \c {.depends} modifier use.
    \row
        \li {1, 2} binary
        \li \c {x11}
        \li \e {Linux only:} identifies target as a X11 application or library if Qt \c {gui} module 
            is used.
    \row
        \li \c {skip_target_version_ext}
        \li \e {Windows only:} version number is removed on target file name.
    \row
        \li application
        \li \c {windows}
        \li \e {Windows only:} identifies target as a windowed application if Qt \c {gui} module is 
            used or if target is not identified as a \c {console} application.
    \endtable

    See also \l {PROPERTIES} variable for more details about target properties.
    
    \section3 Target Dependencies

    Binary target only. Specifies static and shared libraries dependencies by using 
    \l {add_library(type, path, targets)} {add_library()} function. Prefers using this function to 
    qmake variables, since it automatically manages the related qmake variables assignment according 
    to the type of library. Likewise, specifies plugin libraries dependencies by using 
    \l {add_plugin(path, targets)} {add_plugin()} function.
    
    According to the current project type, following rules are applied:
    
    \list
        \li static library target supports only combination of other archives; any library linked to
            this target will be ignored.
        \li application or shared library target supports archives and shared libraries link; 
            archives combination is not applicable.
    \endlist
    
    Library dependencies support optional debug modifiers syntax, such as described in \l {Target 
    Definition} section.
    
    For example:

    \snippet doc_src_mkspecs-manual.pro  LIBRARIES rules
    
    \section3 Outputs Definition
            
    Binary target only. Below directories are defined to store files generated by the compiler:

    \list
        \li intermediate generated files root path: \tt {generated/$${\l {TOOLKIT}.mkspec}/${LIBRARY_MODE}/${BUILD_MODE}}.
        \li default built output files path: \tt {builds/$${\l {TOOLKIT}.mkspec}/${LIBRARY_MODE}/${BUILD_MODE}}, 
            overridable by using \c {DESTDIR} or \c {DLLDESTDIR} variable.
    \endlist

    \section3 Installation Definition

    \l {INSTALLDIR} variable specifies the root directory for any item \c {path} defined in 
    \c {INSTALLS}. If not defined, current project file path will be taken into account by default.
    
    For example:

    \snippet doc_src_mkspecs-manual.pro  INSTALLDIR rules
    
    Note that QS features implement \c {INSTALLS} support for Visual C++ projects, by generating an 
    additional batch file (named \e {project name}\c{.install.bat}) which provides installation 
    rules. This file implements an install target by build mode if there are more than one (in this 
    case, targets can be passed as batch arguments).
            
    \section3 Compiler Options
    
    Binary target only. QS features overrides default compiler and linker options defined by qmake 
    mkspecs. Below table lists additional and overriden compilation rules implemented:
    
    \table
    \header
        \li Scope
        \li Value
        \li Description
    \header
        \li {3, 1} Preprocessor Macros
    \row
        \li 
        \li \c {NDEBUG}
        \li \e {\c {release} mode only:} disables assertions.
    \row
        \li {1, 4} \span {class=nowrap} {Windows based}
        \li \c {_WIN32} \br
            \c {_WIN64}
        \li Standard Windows 32/64 bits platform preprocessor macros.
    \row
        \li \c {UNICODE} \br
            \c {_UNICODE}
        \li Enables Unicode characters set. \br
            \e {Visual C++ compiler only:} not applicable if multi-byte character set (\c {_MBCS} 
            preprocessor macro) is defined.
    \row
        \li \c {_USE_MATH_DEFINES}
        \li Enables mathematical constants defined in C/C++ math headers.
    \row
        \li \c {WIN32_LEAN_AND_MEAN}
        \li Excludes APIs such as Cryptography, DDE, RPC, Shell, and Windows Sockets.
    \row
        \li {1, 2} Linux based
        \li \c {__linux__}
        \li Standard Linux platform preprocessor macro.
    \row
        \li {3, 1}
    \header
        \li {3, 1} C/C++ Compiler Options       
    \row
        \li {1, 5} Visual C++
        \li \c {/MP}
        \li Enables multi-processors compilation.
    \row
        \li \c {/RTCs}
        \li \e {\c {debug} mode only:} enables stack frame run-time errors check.
    \row
        \li no \c {/RTC} flag
        \li \e {\c {release} mode only:} disables run-time errors checks.
    \row
        \li no \c {/EH} flag
        \li \e {\c {no_exceptions} option only:} defines no exception handling model.
    \row
        \li \c {/W4}
        \li \e {\c {warn_on} option only:} enables level 4 compiler warnings. \br
            \e {Visual C++ compiler only:} for Qt-based projects, following level 4 warnings are 
            deactivated:
            \list
                \li C4127, C4512 and C4714 in any mode.
                \li C4718 in \c {release} mode only.
            \endlist
    \row
        \li {3, 1}
    \header
        \li {3, 1} Linker Options       
    \row
        \li Visual C++
        \li \c {/INCREMENTAL:NO}
        \li Disables incremental link.
    \row
        \li GCC
        \li \c {-Wl,-rpath $$ORIGIN}
        \li Add application path to shared libraries search path.
    \endtable        
*/


/*!
    \page mkspecs-metadata-generation.html
    \title Metadata Generation
    \previouspage Predefined Rules
    \nextpage Reference
    
    
