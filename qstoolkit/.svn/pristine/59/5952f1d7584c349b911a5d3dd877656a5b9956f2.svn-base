# -- TO REMOVE: deprecated rules skip Visual C++ precompiled header rules -- #
!deprecated_rules {
# -- TO REMOVE: deprecated rules skip Visual C++ precompiled header rules -- #


msvc-proj: \
!isEmpty( INSTALLS ) {

    # -- Installation targets resolution -- #

    # For any target, following install targets will be taken into account:
    #   - debug and release if debug_and_release option is set
    #   - static and shared if static_and_shared option is set
    #   - combination of both if debug_and_release and static_and_shared options are set

    debug_and_release: \
        MSVCPROJ_INSTALL_TARGETS = debug release

    static_and_shared {

        isEmpty( MSVCPROJ_INSTALL_TARGETS ): \
            MSVCPROJ_INSTALL_TARGETS = static shared

        else {

            _build_modes = $${MSVCPROJ_INSTALL_TARGETS}
            clear( MSVCPROJ_INSTALL_TARGETS )

            for( build_mode, _build_modes ) {

                MSVCPROJ_INSTALL_TARGETS *= static-$${build_mode}
                MSVCPROJ_INSTALL_TARGETS *= shared-$${build_mode}
            }

            unset( _build_modes )
        }
    }


    # -- Installation current target definition -- #
    # -- (in case of multiple install targets)  -- #

    build_pass(): \
    !isEmpty( MSVCPROJ_INSTALL_TARGETS ) {

        static_and_shared {

            TEMPLATE( shared ):       MSVCPROJ_INSTALL_TARGET = shared
            else: TEMPLATE( static ): MSVCPROJ_INSTALL_TARGET = static
        }

        debug_and_release {

            !isEmpty( MSVCPROJ_INSTALL_TARGET ): \
                MSVCPROJ_INSTALL_TARGET = $${MSVCPROJ_INSTALL_TARGET}-

            build_mode( release ):     MSVCPROJ_INSTALL_TARGET = $${MSVCPROJ_INSTALL_TARGET}release
            else: build_mode( debug ): MSVCPROJ_INSTALL_TARGET = $${MSVCPROJ_INSTALL_TARGET}debug
        }
    }


    # -- Visual C++ install batch file generation -- #

    mkspec_makefile: \
        msvc_install.target = .$${TOOLKIT.mkspec}

    msvc_install.template = $${PWD}/../generators/msvc_install.prg
    msvc_install.target   = $${OUT_PWD}/$$TARGET()$${msvc_install.target}.install.bat

    METADATA += msvc_install
    QMAKE_METADATA_GENERATORS += msvc_install


    # -- Installation after build configuration -- #

    build_pass( aux|binary ) {

        build_pass( aux )| \
        build_and_install: \
            QMAKE_POST_LINK += $$quote( "call $$basename( msvc_install.target ) $${MSVCPROJ_INSTALL_TARGET}" )
    }
}


}
