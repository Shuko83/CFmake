# -- Target build modes configuration -- #
#    overrides default behaviour: debug_and_release only available for Visual C++ projects
#    disables project built in both debug and release modes by default
#    if debug or release CONFIG option is set in qmake arguments, debug_and_release option will be disabled

# When using the debug_and_release option (by default on Windows), the project includes a rule that builds both versions
# Then the project will be processed three times:
#   - one time to produce a meta-target
#   - two more times to produce a debug and a release target (with a build_pass flag added in CONFIG variable)
# If static_and_shared option is set, debug and release build passes are repeated for each type of library

msvc-proj: CONFIG *= debug_and_release
else: CONFIG -= debug_and_release

find( QMAKE_ARGS, ^CONFIG[ ]*\\+=(?:(?:.+[ ])?|[ ]*)(?:debug|release)(?:[ ]|$) ): \
    CONFIG *= debug_or_release

debug_and_release {

    !TEMPLATE( binary ): \
        CONFIG -= debug_and_release_target

    CONFIG -= build_all
}


# -- Library build modes configuration -- #
#    disables project built in both static and shared modes by default
#    if static, staticlib, shared, dll or dylib CONFIG option is set in qmake arguments, static_and_shared option will be disabled

# When using the static_and_shared option for library target, the project includes a rule that builds both versions
# Then the project will be processed three times:
#   - one time to produce a meta-target
#   - two more times to produce a static and a shared library target (with a build_pass flag added in CONFIG variable)
# If debug_and_release option is set, static and shared library passes are repeated for each build mode

CONFIG -= static_and_shared

find( QMAKE_ARGS, ^CONFIG[ ]*\\+=(?:(?:.+[ ])?|[ ]*)(?:static|staticlib|shared|dll|dylib)(?:[ ]|$) ): \
    CONFIG *= static_or_shared


# -- Compilation warnings configuration -- #
#    by default: - prints as many warnings as possible
#                - disables Qt private headers include warnings

CONFIG *= warn_on no_private_qt_headers_warning
CONFIG -= warn_off


# -- Compiler exception support -- #
#    by default: enables exception support

CONFIG *= exceptions
CONFIG -= exceptions_off


# -- Compiler RTTI support -- #
#    by default: enables RTTI support

CONFIG *= rtti
CONFIG -= rtti_off


# -- Compiler STL support -- #
#    by default: enables STL support

CONFIG *= stl
CONFIG -= stl_off


# -- Compiler miscellaneous supports -- #
#    by default: - enables C++11 support (Qt 5.0 and later)
#                - disables C++14 support (Qt 5.4 and later)
#                - enables thread support
#                - omits project directory from include paths
#                - appends the value of INCLUDEPATH to DEPENDPATH
#                - disables Lex and Yacc supports
#                - disables precompiled headers support
#                - ensures LIBS variable to be reduced to a list of unique libraries
#                - disables release with debug info mode

CONFIG *= c++11
CONFIG -= c++14

CONFIG *= thread
CONFIG *= no_include_pwd
CONFIG *= depend_includepath

CONFIG -= lex yacc
CONFIG -= precompile_header
CONFIG -= no_lflags_merge
CONFIG -= force_debug_info


# -- Static libraries dependencies support -- #
#    by default: deactivates static libraries qmake tracking

CONFIG -= create_prl


# -- Target features configuration -- #

CONFIG -= windows console testcase  # removes application specific features
CONFIG -= static staticlib          # removes static library specific features
CONFIG -= shared dll dylib          # removes shared library specific features
CONFIG -= plugin                    # removes plugin specific features
CONFIG -= x11                       # removes X11 application/library specific features


# -- Platform specific features configuration -- #

win32 {

    CONFIG *= embed_manifest_dll    # embeds a manifest file in the .dll created as part of a library project
    CONFIG *= embed_manifest_exe    # embeds a manifest file in the .exe created as part of an application project

    msvc {

        CONFIG -= flat              # groups the files within the source/header group depending on the directory they reside (Visual C++ projects only)
        CONFIG -= incremental       # disables incremental linking (Visual C++ compiler only)
    }
}

else: linux {

    CONFIG *= largefile             # includes support for large files
    CONFIG -= separate_debug_info   # deactivates debugging information for applications/shared libraries in separate files
}
