# -- Metadata generator conditions -- #

!msvc-proj: \
    qswarning( "MSVC project template required. Visual C++ install batch file generation skipped..." )
    
else: isEmpty( INSTALLS ): \
    qswarning( "Empty INSTALLS variable value detected. Visual C++ install batch file generation skipped..." )
    
else {
    
    
    # -- Install commands resolution -- #
    
    qtLessThan( 5.5 ) {
    
        QMAKE_INSTALL_DIR  = $$quote( XCOPY /S /Q /Y /I )
        QMAKE_INSTALL_FILE = $$quote( COPY /Y )
    }
    
    else {
    
        QMAKE_INSTALL_DIR  = $$upper( $${QMAKE_INSTALL_DIR} )
        QMAKE_INSTALL_FILE = $$upper( $${QMAKE_INSTALL_FILE} )
    }

    
    # -- Project files to install resolution -- #
        
    build_pass() {
    
        for( install, INSTALLS ) {
                
            equals( install, target ) {
            
                target.files *= $${DESTDIR}/$${TARGET}$${TARGET_EXT}

                TEMPLATE( shared ):  target.files *= $${DESTDIR}/$${TARGET}$${QMAKE_EXT_IMPLIB}
                build_mode( debug ): target.files *= $${DESTDIR}/$${TARGET}.pdb
            }
            
            else {

                _install_files = $$eval( $${install}.files )
                _install_config = $$eval( $${install}.CONFIG )
            
                !contains( _install_config, no_check_exist ) {
            
                    clear( $${install}.files )
                    
                    for( file, _install_files ) {
                    
                        file = $$absolute_path( $${file}, $${_PRO_FILE_PWD_} )
                        exists( $${file} ): eval( $${install}.files *= $$files( $${file} ) )
                    }
                }
                
                unset( _install_files )
                unset( _install_config )
            }
        }
    }
    
    
    # -- Visual C++ install batch file generation -- #
    
    on_writer_start() {

        append_line(             "@ECHO OFF" )        
        
        !isEmpty( MSVCPROJ_INSTALL_TARGETS ) {
        
            append_line()
            append_line(         "SET targets=%~1" )
            append_line(         "IF \"%targets%\" == \"\" ( SET targets=$${MSVCPROJ_INSTALL_TARGETS} )" )
            append_line()
            append_line(         "FOR %%t IN (%targets%) DO (" )
            append_line()
            
            for( target, MSVCPROJ_INSTALL_TARGETS ): \
                append_line(         "IF \"%%t\" == \"$${target}\" CALL:$${target}" )
            
            append_line()
            append_line(         ")" )
            append_line()
            append_line(         "GOTO:eof" )
        }
    }
        
    build_pass() {
    
        !isEmpty( MSVCPROJ_INSTALL_TARGETS ): \
            assert( !isEmpty( MSVCPROJ_INSTALL_TARGET ) )
        
        !isEmpty( MSVCPROJ_INSTALL_TARGET ) {
        
            append_line()
            append_line(         ":$${MSVCPROJ_INSTALL_TARGET}" )
        }
        
        for( install, INSTALLS ) {
        
            !isEmpty( $${install}.extra )| \
            !isEmpty( $${install}.files ) {

                _install_path = $$eval( $${install}.path )
                _install_config = $$eval( $${install}.CONFIG )

                contains( _install_config, relative_path ) {

                    _install_path = %~dp0/$$relative_path( $${_install_path}, $${_PRO_FILE_PWD_} )
                    eval( $${install}.path = $${_install_path} )
                }

                append_line()
                append_line(     "IF NOT EXIST \"$$system_path( $$eval( $${install}.path ) )\" MKDIR \"$$system_path( $$eval( $${install}.path ) )\"" )
                append_line(     "IF NOT EXIST \"$$system_path( $$eval( $${install}.path ) )\" EXIT 1" )
                        
                !isEmpty( $${install}.extra ): \
                    append_line( "$$eval( $${install}.extra )" )
                    
                for( file, $${install}.files ) {
                
                    file = $$absolute_path( $${file}, $${_PRO_FILE_PWD_} )
                    
                    contains( _install_config, no_check_exist ) {
                    
                        _install_command = $${QMAKE_INSTALL_FILE}
                    
                        contains( _install_config, directory ): \
                            _install_command = $${QMAKE_INSTALL_DIR}
                    }
                    
                    else {
                    
                        _install_command = $$system( "IF EXIST \"$$system_path( $${file}/* )\" \
                                                      ( ECHO $${QMAKE_INSTALL_DIR} ) ELSE \
                                                      ( ECHO $${QMAKE_INSTALL_FILE} )" )
                        
                        equals( _install_command, $${QMAKE_INSTALL_DIR} ) {
                        
                            contains( _install_config, relative_path ): _install_path = $${_install_path}/$$basename( file )
                            else: _install_path = $$absolute_path( $$basename( file ), $${_install_path} )
                        }
                    }

                    contains( _install_config, relative_path ): \
                        file = %~dp0/$$relative_path( $${file}, $${_PRO_FILE_PWD_} )
                    
                    append_line( "$${_install_command} \"$$system_path( $${file} )\" \"$$system_path( $${_install_path} )\"" )
                }
                
                unset( _install_path )
                unset( _install_config )
                unset( _install_command )
            }
        }
        
        !isEmpty( MSVCPROJ_INSTALL_TARGET ) {
        
            append_line()
            append_line(         "GOTO:eof" )
        }
    }
}
