#ifndef CMAKE_VERSION_INFO_H
#define CMAKE_VERSION_INFO_H


#ifndef PRODUCT_NAME
#define PRODUCT_NAME         "@PARAMS_PRODUCT@\0"
#endif

#ifndef PRODUCT_COMPANY
#define PRODUCT_COMPANY      "@PARAMS_COMPANY@\0"
#endif

#ifndef PRODUCT_COPYRIGHT
#define PRODUCT_COPYRIGHT    "@PARAMS_COPYRIGHT@\0"
#endif

#ifndef PRODUCT_DESCRIPTION
#define PRODUCT_DESCRIPTION  "@PARAMS_DESCRIPTION@\0"
#endif


#ifndef PRODUCT_MAJOR_VERSION
#define PRODUCT_MAJOR_VERSION  @PARAMS_MAJOR_VERSION@
#endif

#ifndef PRODUCT_MINOR_VERSION
#define PRODUCT_MINOR_VERSION  @PARAMS_MINOR_VERSION@
#endif

#ifndef PRODUCT_PATCH_VERSION
#define PRODUCT_PATCH_VERSION  @PARAMS_PATCH_VERSION@
#endif

#ifndef PRODUCT_BUILD_VERSION
#define PRODUCT_BUILD_VERSION  @PARAMS_BUILD_VERSION@
#endif


#ifndef __TO_STRING
#define __TO_STRING_IMPL(x) #x
#define __TO_STRING(x) __TO_STRING_IMPL(x)
#endif

#define PRODUCT_MAJOR_MINOR_VERSION            __TO_STRING(PRODUCT_MAJOR_VERSION) "." __TO_STRING(PRODUCT_MINOR_VERSION)
#define PRODUCT_MAJOR_MINOR_PATCH_VERSION      PRODUCT_MAJOR_MINOR_VERSION "." __TO_STRING(PRODUCT_PATCH_VERSION)

#define PRODUCT_VERSION                        PRODUCT_MAJOR_MINOR_PATCH_VERSION "." __TO_STRING(PRODUCT_BUILD_VERSION) "\0"
#define PRODUCT_VERSION_RESOURCE               PRODUCT_MAJOR_VERSION,PRODUCT_MINOR_VERSION,PRODUCT_PATCH_VERSION,PRODUCT_BUILD_VERSION


#endif
