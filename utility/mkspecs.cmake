if(WIN32)
    set(CSTOOLKIT_HOST_PLATFORM "win")
elseif(LINUX)
    set(CSTOOLKIT_HOST_PLATFORM "linux")
else()
    message(WARNING "CSToolkit: Unsuported platform ${CMAKE_SYSTEM_NAME} by CSToolkit")
    set(CSTOOLKIT_HOST_PLATFORM "unsuported")
endif()

if(CMAKE_CXX_COMPILER_ID STREQUAL "MSVC")
    set(CSTOOLKIT_COMPILER_NAME "msvc")

    if(MSVC_VERSION EQUAL 1500)
        set(CSTOOLKIT_COMPILER_VERSION "2008")
    elseif(MSVC_VERSION EQUAL 1600)
        set(CSTOOLKIT_COMPILER_VERSION "2010")
    elseif(MSVC_VERSION EQUAL 1700)
        set(CSTOOLKIT_COMPILER_VERSION "2012")
    elseif(MSVC_VERSION EQUAL 1800)
        set(CSTOOLKIT_COMPILER_VERSION "2013")
    elseif(MSVC_VERSION EQUAL 1900)
        set(CSTOOLKIT_COMPILER_VERSION "2015")
    elseif(MSVC_VERSION GREATER_EQUAL 1910 AND MSVC_VERSION LESS 1920)
        set(CSTOOLKIT_COMPILER_VERSION "2017")
    elseif(MSVC_VERSION GREATER_EQUAL 1920 AND MSVC_VERSION LESS 1930)
        set(CSTOOLKIT_COMPILER_VERSION "2019")
    elseif(MSVC_VERSION GREATER_EQUAL 1930 AND MSVC_VERSION LESS 1950)
        set(CSTOOLKIT_COMPILER_VERSION "2022")
    else()
        message(WARNING "CSToolkit: Unsuported msvc version ${MSVC_VERSION} by CSToolkit")
        set(CSTOOLKIT_COMPILER_VERSION "unsuported")
    endif()
elseif(CMAKE_CXX_COMPILER_ID STREQUAL "GNU")
    set(CSTOOLKIT_COMPILER_NAME "gcc")

    string(REGEX MATCH "^[^.]+\\.[^.]+" CSTOOLKIT_COMPILER_VERSION_MAJOR_MINOR ${CMAKE_CXX_COMPILER_VERSION})
    string(REGEX MATCH "^[^.]+\\.[^.]+\\.[^.]+" CSTOOLKIT_COMPILER_VERSION_MAJOR_MINOR_PATCH ${CMAKE_CXX_COMPILER_VERSION})

    if(CMAKE_CXX_COMPILER_VERSION VERSION_LESS 5)
        set(CSTOOLKIT_COMPILER_VERSION "${CSTOOLKIT_COMPILER_VERSION_MAJOR_MINOR_PATCH}")
    else()
        set(CSTOOLKIT_COMPILER_VERSION "${CSTOOLKIT_COMPILER_VERSION_MAJOR_MINOR}")
    endif()
elseif(CMAKE_CXX_COMPILER_ID STREQUAL "Borland")
    set(CSTOOLKIT_COMPILER_NAME "bl")
    set(CSTOOLKIT_COMPILER_VERSION "2010")
else()
    message(WARNING "CSToolkit: Unsuported compiler ${CMAKE_CXX_COMPILER_ID} by CSToolkit")
    set(CSTOOLKIT_COMPILER_VERSION "unsuported")
endif()

if(CMAKE_SIZEOF_VOID_P EQUAL 4)
    set(CSTOOLKIT_HOST_ARCH "x86")
elseif(CMAKE_SIZEOF_VOID_P EQUAL 8)
    set(CSTOOLKIT_HOST_ARCH "x64")
else()
    message(WARNING "CSToolkit: Unsuported architecture ${CMAKE_SYSTEM_PROCESSOR} by CSToolkit")
    set(CSTOOLKIT_HOST_ARCH "unsuported")
endif()

set(CSTOOLKIT_COMPILER "${CSTOOLKIT_COMPILER_NAME}${CSTOOLKIT_COMPILER_VERSION}")

set(CSTOOLKIT_BUILD_MKSPECS "${CSTOOLKIT_HOST_PLATFORM}-${CSTOOLKIT_COMPILER}-${CSTOOLKIT_HOST_ARCH}")
