if(WIN32)
    set(CFMAKE_HOST_PLATFORM "win")
elseif(LINUX)
    set(CFMAKE_HOST_PLATFORM "linux")
else()
    message(NOTICE ${COLOR_YELLOW_BOLD} "CFMake: Unsupported platform ${CMAKE_SYSTEM_NAME}" ${COLOR_RESET})
    set(CFMAKE_HOST_PLATFORM "unsupported")
endif()

if(CMAKE_CXX_COMPILER_ID)
    if(CMAKE_CXX_COMPILER_ID STREQUAL "MSVC")
        set(CFMAKE_COMPILER_NAME "msvc")

        if(MSVC_VERSION EQUAL 1500)
            set(CFMAKE_COMPILER_VERSION "2008")
        elseif(MSVC_VERSION EQUAL 1600)
            set(CFMAKE_COMPILER_VERSION "2010")
        elseif(MSVC_VERSION EQUAL 1700)
            set(CFMAKE_COMPILER_VERSION "2012")
        elseif(MSVC_VERSION EQUAL 1800)
            set(CFMAKE_COMPILER_VERSION "2013")
        elseif(MSVC_VERSION EQUAL 1900)
            set(CFMAKE_COMPILER_VERSION "2015")
        elseif(MSVC_VERSION GREATER_EQUAL 1910 AND MSVC_VERSION LESS 1920)
            set(CFMAKE_COMPILER_VERSION "2017")
        elseif(MSVC_VERSION GREATER_EQUAL 1920 AND MSVC_VERSION LESS 1930)
            set(CFMAKE_COMPILER_VERSION "2019")
        elseif(MSVC_VERSION GREATER_EQUAL 1930 AND MSVC_VERSION LESS 1950)
            set(CFMAKE_COMPILER_VERSION "2022")
        else()
            message(NOTICE ${COLOR_YELLOW_BOLD} "CFMake: Unsupported msvc version ${MSVC_VERSION}" ${COLOR_RESET})
            set(CFMAKE_COMPILER_VERSION "unsupported")
        endif()
    elseif(CMAKE_CXX_COMPILER_ID STREQUAL "GNU")
        set(CFMAKE_COMPILER_NAME "gcc")

        string(REGEX MATCH "^[^.]+\\.[^.]+" CFMAKE_COMPILER_VERSION_MAJOR_MINOR ${CMAKE_CXX_COMPILER_VERSION})
        string(REGEX MATCH "^[^.]+\\.[^.]+\\.[^.]+" CFMAKE_COMPILER_VERSION_MAJOR_MINOR_PATCH ${CMAKE_CXX_COMPILER_VERSION})

        if(CMAKE_CXX_COMPILER_VERSION VERSION_LESS 5)
            set(CFMAKE_COMPILER_VERSION "${CFMAKE_COMPILER_VERSION_MAJOR_MINOR_PATCH}")
        else()
            set(CFMAKE_COMPILER_VERSION "${CFMAKE_COMPILER_VERSION_MAJOR_MINOR}")
        endif()
    elseif(CMAKE_CXX_COMPILER_ID STREQUAL "Borland")
        set(CFMAKE_COMPILER_NAME "bl")
        set(CFMAKE_COMPILER_VERSION "2010")
    else()
        message(NOTICE ${COLOR_YELLOW_BOLD} "CFMake: Unsupported compiler ${CMAKE_CXX_COMPILER_ID}" ${COLOR_RESET})
        set(CFMAKE_COMPILER_VERSION "unsupported")
    endif()
    if(CMAKE_SIZEOF_VOID_P EQUAL 4)
        set(CFMAKE_HOST_ARCH "x86")
    elseif(CMAKE_SIZEOF_VOID_P EQUAL 8)
        set(CFMAKE_HOST_ARCH "x64")
    else()
        message(NOTICE ${COLOR_YELLOW_BOLD} "CFMake: Unsupported architecture ${CMAKE_SYSTEM_PROCESSOR}" ${COLOR_RESET})
        set(CFMAKE_HOST_ARCH "unsupported")
    endif()
elseif(CMAKE_CSharp_COMPILER_ID)
    set(CFMAKE_COMPILER_NAME "dotnet")
    set(CFMAKE_COMPILER_VERSION "4.7.2")
    set(CFMAKE_HOST_ARCH "x64")
else()
    set(CFMAKE_COMPILER_NAME "unsupported")
    set(CFMAKE_COMPILER_VERSION "")
    set(CFMAKE_HOST_ARCH "unsupported")
endif()

set(CFMAKE_COMPILER "${CFMAKE_COMPILER_NAME}${CFMAKE_COMPILER_VERSION}")

set(CFMAKE_BUILD_MKSPECS "${CFMAKE_HOST_PLATFORM}-${CFMAKE_COMPILER}-${CFMAKE_HOST_ARCH}")
