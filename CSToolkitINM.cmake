if(NOT $ENV{VERSION} STREQUAL "")
	set(INM_ENV_VERSION $ENV{VERSION})
elseif(NOT $ENV{PRODUCTVERSION} STREQUAL "")
	set(INM_ENV_VERSION $ENV{PRODUCTVERSION})
endif()

if(INM_ENV_VERSION MATCHES "^[0-9]+\\.[0-9]+\\.[0-9]+(\\.[0-9]+)?(-.+)?$")
	if(NOT $ENV{BUILDNUMBER} STREQUAL "")
		set(CSTOOLKIT_PROJECT_VERSION ${INM_ENV_VERSION}.$ENV{BUILDNUMBER})
	elseif(NOT $ENV{BUILD_NUMBER} STREQUAL "")
		set(CSTOOLKIT_PROJECT_VERSION ${INM_ENV_VERSION}.$ENV{BUILD_NUMBER})
	else()
		set(CSTOOLKIT_PROJECT_VERSION ${INM_ENV_VERSION}.0)
	endif()
endif()

include(${CMAKE_CURRENT_LIST_DIR}/CSToolkit.cmake)
set(CSTOOLKIT_AUTO_FIND_PACKAGE ON)
set(CSTOOLKIT_CHECK_DEPENDENCIES ON)

if(WIN32)
    add_compile_definitions(QT_LARGEFILE_SUPPORT _CRT_SECURE_NO_WARNINGS Q_WS_WIN)
endif()

if(WIN32)
    set(INM_LIB_TYPE SHARED)
else()
    set(INM_LIB_TYPE STATIC)
endif()